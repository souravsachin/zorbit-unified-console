    },

    "security-full": {
      "name": "Full Security Audit",
      "description": "Complete security verification: admin access, RBAC, settings, consent",
      "segments": [
        "login-as-admin",
        "admin-full-access",
        "rbac-api-enforcement",
        "login-as-non-admin",
        "non-admin-restricted",
        "security-settings",
        "consent-screen"
      ]
    }
  },

  "bouquets": {

    "rbac-audit": {
      "name": "RBAC Audit",
      "description": "AZ-2039: Full RBAC audit — admin access + non-admin restrictions + API enforcement",
      "mode": "sequential",
      "journeys": ["security-admin-access", "security-rbac-enforcement"]
    },

    "security-settings": {
      "name": "Security Settings",
      "description": "ID-2040, ID-2041: Consent screen + password hashing mode + compliance badges",
      "mode": "sequential",
      "journeys": ["security-settings-and-consent"]

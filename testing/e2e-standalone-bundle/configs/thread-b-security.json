        { "action": "wait", "timeout": 1500 },
        {
          "action": "fill",
          "selector": "input[type='email'], input[name='email'], input[placeholder*='email' i]",
          "value": "${credentials.admin.email}"
        },
        {
          "action": "fill",
          "selector": "input[type='password']",
          "value": "${credentials.admin.password}"
        },
        {
          "action": "click",
          "selector": "button[type='submit'], button:has-text('Sign in'), button:has-text('Login')"
        },
        { "action": "wait", "timeout": 4000 },
        {
          "action": "assertVisible",
          "selector": "nav, aside, [class*='sidebar'], [role='navigation'], main",
          "timeout": 20000
        },
        {
          "action": "navigate",
          "url": "/app/settings",
          "announce": { "before": "ID-2041: Navigating to Settings page" }
        },
        { "action": "wait", "timeout": 3000 },
        {
          "action": "assertVisible",
          "selector": "main, [class*='content'], [class*='settings'], h1, h2",
          "timeout": 12000,
          "announce": { "after": "Settings page loaded" }
        },
        {
          "action": "screenshot",
          "value": "sec-11-settings-page.png"
        },
        {
          "action": "navigate",
          "url": "/app/identity/setup",
          "announce": { "before": "ID-2041: Checking Identity Setup for security configuration" }

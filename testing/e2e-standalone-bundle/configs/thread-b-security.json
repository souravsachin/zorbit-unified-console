        },
        { "action": "wait", "timeout": 3000 },
        {
          "action": "screenshot",
          "value": "sec-07-non-admin-users-attempt.png",
          "announce": { "after": "Captured non-admin user management access attempt" }
        },
        {
          "action": "navigate",
          "url": "/app/identity/organizations",
          "announce": { "before": "AZ-2039: Non-admin attempting to access organizations" }
        },
        { "action": "wait", "timeout": 3000 },
        {
          "action": "screenshot",
          "value": "sec-08-non-admin-orgs-attempt.png",
          "announce": { "after": "Captured non-admin organization access attempt" }
        },
        {
          "action": "navigate",
          "url": "/app/authorization/roles",
          "announce": { "before": "AZ-2039: Non-admin attempting to access role management" }
        },
        { "action": "wait", "timeout": 3000 },
        {
          "action": "screenshot",
          "value": "sec-09-non-admin-roles-attempt.png",
          "announce": { "after": "Captured non-admin roles access attempt" }
        },
        {
          "action": "navigate",
          "url": "/app/admin/module-registry",
          "announce": { "before": "AZ-2039: Non-admin attempting to access admin module registry" }
        },
        { "action": "wait", "timeout": 3000 },
        {
          "action": "screenshot",
          "value": "sec-10-non-admin-admin-attempt.png",
          "announce": { "after": "AZ-2039: Non-admin access restriction tests complete" }
        }
      ]
    },

    "security-settings": {
      "name": "ID-2041: Security Settings Page",

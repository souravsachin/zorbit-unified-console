{
  "baseUrl": "https://zorbit.scalatics.com",
  "viewport": { "width": 1440, "height": 900 },
  "defaults": {
    "timeout": 15000,
    "waitAfterAction": 1000,
    "waitForNetworkIdle": false
  },
  "segments": {
    "pcg4-login": {
      "name": "Login for PCG4",
      "description": "Authenticate with admin credentials to access Product Configurator",
      "steps": [
        {
          "action": "navigate",
          "url": "/login",
          "announce": { "before": "Navigating to Zorbit login for Product Configurator testing" }
        },
        { "action": "wait", "timeout": 1500 },
        {
          "action": "fill",
          "selector": "input[type='email'], input[placeholder*='email' i], input[name='email']",
          "value": "${credentials.admin.email}"
        },
        {
          "action": "fill",
          "selector": "input[type='password']",
          "value": "${credentials.admin.password}"
        },
        {
          "action": "click",
          "selector": "button[type='submit'], button:has-text('Sign in'), button:has-text('Login')",
          "announce": { "after": "Login submitted" }
        },
        { "action": "wait", "timeout": 2000 },
        {
          "action": "custom",
          "handler": "generateTotp",
          "description": "Generate TOTP for MFA",
          "params": { "command": "ssh sovpn 'bash /tmp/get-totp.sh'" },
          "selector": "input[inputmode='numeric'], input[maxlength='6'], input[placeholder='000000']",
          "announce": { "before": "Entering MFA code" }
        },
        {
          "action": "click",
          "selector": "button[type='submit'], button:has-text('Verify')"
        },
        { "action": "wait", "timeout": 3000 },
        {
          "action": "waitForUrl",
          "pattern": "/(dashboard|home|app)",
          "timeout": 20000,
          "announce": { "after": "Logged in successfully. Ready for PCG4 testing." }
        },
        {
          "action": "screenshot",
          "value": "pcg4-00-logged-in.png"
        }
      ]
    },

    "pcg4-list-configs": {
      "name": "List Existing Configurations",
      "description": "Navigate to the PCG4 Dashboard and verify the configurations list table loads",
      "steps": [
        {
          "action": "navigate",
          "url": "/app/pcg4/configurations",
          "announce": { "before": "Navigating to Product Configurator dashboard" }
        },
        { "action": "wait", "timeout": 3000 },
        {
          "action": "assertVisible",
          "selector": "h1:has-text('Product Configurator')",
          "timeout": 10000,
          "announce": { "after": "Product Configurator dashboard loaded" }
        },
        {
          "action": "screenshot",
          "value": "pcg4-list-01-dashboard.png"
        },
        {
          "action": "assertVisible",
          "selector": "h2:has-text('Configurations'), table, :has-text('No configurations yet')",
          "timeout": 8000,
          "announce": { "after": "Configurations list or empty state visible" }
        },
        {
          "action": "assertVisible",
          "selector": "button:has-text('New Configuration')",
          "timeout": 5000,
          "announce": { "after": "New Configuration button is present" }
        },
        {
          "action": "screenshot",
          "value": "pcg4-list-02-configs-table.png",
          "announce": { "after": "Configurations list captured with status badges, plan counts, and action buttons." }
        }
      ]
    },

    "pcg4-start-new": {
      "name": "Start New Configuration",
      "description": "Click New Configuration button to launch the 8-step wizard",
      "steps": [
        {
          "action": "click",
          "selector": "button:has-text('New Configuration')",
          "announce": { "before": "Starting a new product configuration" }
        },
        { "action": "wait", "timeout": 2500 },
        {
          "action": "assertVisible",
          "selector": "h2:has-text('Insurer Details')",
          "timeout": 10000,
          "announce": { "after": "Wizard opened. Step 1: Insurer Details is visible." }
        },
        {
          "action": "screenshot",
          "value": "pcg4-start-01-wizard-opened.png"
        }
      ]
    },

    "pcg4-step1-insurer": {
      "name": "Step 1: Insurer Details",
      "description": "Fill insurer name, internal code, regulator code, and description for Emirates Health Shield Insurance",
      "steps": [
        {
          "action": "assertVisible",
          "selector": "h2:has-text('Insurer Details')",
          "timeout": 10000,
          "announce": { "before": "Verifying Step 1 - Insurer Details form is visible" }
        },
        {
          "action": "fill",
          "selector": "input[placeholder*='Healthy Life Insurance']",
          "value": "Emirates Health Shield Insurance",
          "announce": { "before": "Entering insurer name: Emirates Health Shield Insurance" }
        },
        {
          "action": "fill",
          "selector": "input[placeholder*='HLI001']",
          "value": "EHSI-2026",
          "announce": { "after": "Internal code: EHSI-2026" }
        },
        {
          "action": "fill",
          "selector": "input[placeholder*='REG-HLI-2024-001']",
          "value": "REG-EHSI-UAE-2026-001",
          "announce": { "after": "Regulator assigned code: REG-EHSI-UAE-2026-001" }
        },
        {
          "action": "fill",
          "selector": "textarea[placeholder*='description of the insurance company']",
          "value": "Emirates Health Shield Insurance is a leading UAE-based health insurance provider, regulated by the Insurance Authority of the United Arab Emirates. Specializing in comprehensive group and individual health plans for the GCC market since 2005."
        },
        {
          "action": "screenshot",
          "value": "pcg4-step1-01-insurer-filled.png",
          "announce": { "after": "Step 1 complete. Emirates Health Shield Insurance details filled." }
        },
        {
          "action": "click",
          "selector": "button:has-text('Next: Product Details')",
          "announce": { "before": "Proceeding to Step 2 - Product Details" }
        },
        { "action": "wait", "timeout": 2000 }
      ]
    },

    "pcg4-step2-product": {
      "name": "Step 2: Product Details",
      "description": "Fill product name, internal code, regulator code, and description for Comprehensive Health Plus",
      "steps": [
        {
          "action": "assertVisible",
          "selector": "h2:has-text('Product Details')",
          "timeout": 10000,
          "announce": { "before": "Step 2 - Product Details" }
        },
        {
          "action": "click",
          "selector": "button:has-text('Skip'), :has-text('start from scratch')",
          "force": true,
          "announce": { "before": "Skipping inheritance - starting from scratch" }
        },
        { "action": "wait", "timeout": 500 },
        {
          "action": "fill",
          "selector": "input[placeholder*='Comprehensive Health Plus']",
          "value": "Comprehensive Health Plus",
          "announce": { "before": "Product name: Comprehensive Health Plus" }
        },
        {
          "action": "fill",
          "selector": "input[placeholder*='CHP-2024-V1']",
          "value": "CHP-2026-V1",
          "announce": { "after": "Internal product code: CHP-2026-V1" }
        },
        {
          "action": "fill",
          "selector": "input[placeholder*='REG-PROD-CHP-2024-001']",
          "value": "REG-PROD-CHP-UAE-2026-001",
          "announce": { "after": "Regulator assigned product code: REG-PROD-CHP-UAE-2026-001" }
        },
        {
          "action": "fill",
          "selector": "textarea[placeholder*='Describe the insurance product']",
          "value": "Comprehensive health insurance product for the UAE market, covering inpatient, outpatient, dental, optical, maternity, and mental health services. Designed for employer group and individual retail distribution with tiered plan structure (Gold/Silver). Compliant with DHA and HAAD minimum benefit requirements."
        },
        {
          "action": "screenshot",
          "value": "pcg4-step2-01-product-filled.png",
          "announce": { "after": "Step 2 complete. Comprehensive Health Plus product details filled." }
        },
        {
          "action": "click",
          "selector": "button:has-text('Next: Create Plans')",
          "announce": { "before": "Proceeding to Step 3 - Create Plans" }
        },
        { "action": "wait", "timeout": 2000 }
      ]
    },

    "pcg4-step3-plans": {
      "name": "Step 3: Create Plans (Gold + Silver)",
      "description": "Create Gold and Silver tier plans with Middle East region coverage",
      "steps": [
        {
          "action": "assertVisible",
          "selector": "h2:has-text('Create Plans')",
          "timeout": 10000,
          "announce": { "before": "Step 3 - Creating plan tiers" }
        },
        {
          "action": "fill",
          "selector": "input[placeholder*='Health Plus Gold']",
          "value": "EHSI Gold Enhanced",
          "announce": { "before": "Plan 1 name: EHSI Gold Enhanced" }
        },
        {
          "action": "select",
          "selector": "select >> nth=0",
          "value": "Gold",
          "announce": { "after": "Plan tier: Gold" }
        },
        {
          "action": "click",
          "selector": "label:has-text('Middle East') input[type='checkbox'], label:has-text('Middle East')",
          "announce": { "after": "Region: Middle East selected for Plan 1" }
        },
        { "action": "wait", "timeout": 500 },
        {
          "action": "screenshot",
          "value": "pcg4-step3-01-gold-plan.png"
        },
        {
          "action": "click",
          "selector": "button:has-text('Add Another Plan')",
          "announce": { "before": "Adding Silver tier plan" }
        },
        { "action": "wait", "timeout": 1000 },
        {
          "action": "fill",
          "selector": "input[placeholder*='Health Plus Gold'] >> nth=1",
          "value": "EHSI Silver Standard",
          "announce": { "before": "Plan 2 name: EHSI Silver Standard" }
        },
        {
          "action": "select",
          "selector": "select >> nth=3",
          "value": "Silver",
          "announce": { "after": "Plan tier: Silver" }
        },
        {
          "action": "click",
          "selector": ".space-y-6 >> nth=1 >> label:has-text('Middle East') input[type='checkbox'], .space-y-6 >> nth=1 >> label:has-text('Middle East')",
          "announce": { "after": "Region: Middle East selected for Plan 2" }
        },
        { "action": "wait", "timeout": 500 },
        {
          "action": "screenshot",
          "value": "pcg4-step3-02-both-plans.png",
          "announce": { "after": "Two plans created: EHSI Gold Enhanced and EHSI Silver Standard for Middle East." }
        },
        {
          "action": "click",
          "selector": "button:has-text('Next: Base Plan Config')",
          "announce": { "before": "Proceeding to Step 4 - Base Plan Configuration" }
        },
        { "action": "wait", "timeout": 2000 }
      ]
    },

    "pcg4-step4-baseconfig": {
      "name": "Step 4: Base Plan Configuration",
      "description": "Configure general rules and limits for Gold plan (annual limit, deductible, OOP max, waiting period, network)",
      "steps": [
        {
          "action": "assertVisible",
          "selector": "h2:has-text('Base Plan Configuration')",
          "timeout": 10000,
          "announce": { "before": "Step 4 - Base Plan Configuration. Setting general rules and limits." }
        },
        {
          "action": "click",
          "selector": "button:has-text('EHSI Gold Enhanced'), button >> nth=0",
          "announce": { "before": "Selecting Gold plan tab" }
        },
        { "action": "wait", "timeout": 500 },
        {
          "action": "fill",
          "selector": "input[type='number'] >> nth=0",
          "value": "1000000",
          "announce": { "after": "Annual coverage limit: $1,000,000" }
        },
        {
          "action": "fill",
          "selector": "input[type='number'] >> nth=1",
          "value": "500",
          "announce": { "after": "Annual deductible: $500" }
        },
        {
          "action": "fill",
          "selector": "input[type='number'] >> nth=2",
          "value": "10000",
          "announce": { "after": "Out-of-pocket maximum: $10,000" }
        },
        {
          "action": "fill",
          "selector": "input[type='number'] >> nth=3",
          "value": "30",
          "announce": { "after": "Waiting period: 30 days" }
        },
        {
          "action": "select",
          "selector": "select",
          "value": "Both",
          "announce": { "after": "Network restrictions: Both In-Network and Out-of-Network" }
        },
        {
          "action": "screenshot",
          "value": "pcg4-step4-01-gold-config.png",
          "announce": { "after": "Gold plan base config set: $1M limit, $500 deductible, $10K OOP max, 30-day wait, Both networks." }
        },
        {
          "action": "click",
          "selector": "button:has-text('EHSI Silver Standard')",
          "announce": { "before": "Switching to Silver plan tab" }
        },
        { "action": "wait", "timeout": 500 },
        {
          "action": "fill",
          "selector": "input[type='number'] >> nth=0",
          "value": "500000",
          "announce": { "after": "Silver annual coverage limit: $500,000" }
        },
        {
          "action": "fill",
          "selector": "input[type='number'] >> nth=1",
          "value": "1000",
          "announce": { "after": "Silver annual deductible: $1,000" }
        },
        {
          "action": "fill",
          "selector": "input[type='number'] >> nth=2",
          "value": "15000",
          "announce": { "after": "Silver out-of-pocket maximum: $15,000" }
        },
        {
          "action": "fill",
          "selector": "input[type='number'] >> nth=3",
          "value": "60",
          "announce": { "after": "Silver waiting period: 60 days" }
        },
        {
          "action": "select",
          "selector": "select",
          "value": "In-Network",
          "announce": { "after": "Silver network restrictions: In-Network Only" }
        },
        {
          "action": "screenshot",
          "value": "pcg4-step4-02-silver-config.png",
          "announce": { "after": "Silver plan base config set: $500K limit, $1K deductible, $15K OOP max, 60-day wait, In-Network only." }
        },
        {
          "action": "click",
          "selector": "button:has-text('Next: Encounter Config')",
          "announce": { "before": "Proceeding to Step 5 - Encounter Configuration" }
        },
        { "action": "wait", "timeout": 2000 }
      ]
    },

    "pcg4-step5-encounters": {
      "name": "Step 5: Encounter Configuration",
      "description": "Select encounter types from the ZorbitTreePicker taxonomy (inpatient, outpatient, dental, optical, maternity, mental health categories)",
      "steps": [
        {
          "action": "assertVisible",
          "selector": "h2:has-text('Encounter Configuration')",
          "timeout": 10000,
          "announce": { "before": "Step 5 - Encounter Configuration. Loading encounter taxonomy tree." }
        },
        { "action": "wait", "timeout": 2000 },
        {
          "action": "assertVisible",
          "selector": "input[placeholder*='Search encounter types']",
          "timeout": 10000,
          "announce": { "after": "ZorbitTreePicker loaded with searchable encounter taxonomy" }
        },
        {
          "action": "screenshot",
          "value": "pcg4-step5-01-taxonomy-tree.png"
        },
        {
          "action": "click",
          "selector": "button:has-text('EHSI Gold Enhanced'), button >> nth=0",
          "announce": { "before": "Configuring encounters for Gold plan" }
        },
        { "action": "wait", "timeout": 500 },
        {
          "action": "click",
          "selector": "label:has-text('Select All'), button:has-text('Select All'), [class*='select-all']",
          "announce": { "before": "Selecting all encounter types for Gold plan" }
        },
        { "action": "wait", "timeout": 1000 },
        {
          "action": "screenshot",
          "value": "pcg4-step5-02-gold-all-selected.png",
          "announce": { "after": "All encounter types selected for Gold plan" }
        },
        {
          "action": "click",
          "selector": "button:has-text('EHSI Silver Standard')",
          "announce": { "before": "Switching to Silver plan for encounter selection" }
        },
        { "action": "wait", "timeout": 500 },
        {
          "action": "fill",
          "selector": "input[placeholder*='Search encounter types']",
          "value": "Inpatient",
          "announce": { "before": "Searching for Inpatient encounters" }
        },
        { "action": "wait", "timeout": 500 },
        {
          "action": "click",
          "selector": "label:has-text('Select All'), button:has-text('Select All'), [class*='select-all']",
          "announce": { "after": "Selected Inpatient category encounters for Silver" }
        },
        { "action": "wait", "timeout": 300 },
        {
          "action": "fill",
          "selector": "input[placeholder*='Search encounter types']",
          "value": "Outpatient",
          "announce": { "before": "Searching for Outpatient encounters" }
        },
        { "action": "wait", "timeout": 500 },
        {
          "action": "click",
          "selector": "label:has-text('Select All'), button:has-text('Select All'), [class*='select-all']",
          "announce": { "after": "Selected Outpatient category encounters for Silver" }
        },
        { "action": "wait", "timeout": 300 },
        {
          "action": "fill",
          "selector": "input[placeholder*='Search encounter types']",
          "value": "",
          "announce": { "before": "Clearing search filter" }
        },
        { "action": "wait", "timeout": 500 },
        {
          "action": "screenshot",
          "value": "pcg4-step5-03-silver-partial-selected.png",
          "announce": { "after": "Silver plan has Inpatient and Outpatient encounters selected. Gold has all encounter types." }
        },
        {
          "action": "click",
          "selector": "button:has-text('Next: Benefits Setup')",
          "announce": { "before": "Proceeding to Step 6 - Benefits Setup" }
        },
        { "action": "wait", "timeout": 2000 }
      ]
    },

    "pcg4-step6-benefits": {
      "name": "Step 6: Benefits Setup",
      "description": "Configure cost sharing, visit limits, authorization, and exclusions for encounter benefits per plan",
      "steps": [
        {
          "action": "assertVisible",
          "selector": "h2:has-text('Benefits Setup')",
          "timeout": 10000,
          "announce": { "before": "Step 6 - Benefits Setup. Configuring cost sharing and visit limits per encounter." }
        },
        {
          "action": "screenshot",
          "value": "pcg4-step6-01-benefits-overview.png"
        },
        {
          "action": "assertVisible",
          "selector": ":has-text('Encounter Types'), :has-text('Total Encounters')",
          "timeout": 8000,
          "announce": { "after": "Encounter sidebar and benefit detail panel visible" }
        },
        {
          "action": "click",
          "selector": "button:has-text('EHSI Gold Enhanced'), button >> nth=0",
          "announce": { "before": "Configuring benefits for Gold plan" }
        },
        { "action": "wait", "timeout": 500 },
        {
          "action": "assertVisible",
          "selector": "button:has-text('Cost Sharing'), button:has-text('Visit Limits'), button:has-text('Authorization'), button:has-text('Exclusions')",
          "timeout": 8000,
          "announce": { "after": "Benefit detail tabs visible: Cost Sharing, Visit Limits, Authorization, Exclusions" }
        },
        {
          "action": "screenshot",
          "value": "pcg4-step6-02-gold-cost-sharing.png"
        },
        {
          "action": "click",
          "selector": "button:has-text('Visit Limits')",
          "announce": { "before": "Switching to Visit Limits tab" }
        },
        { "action": "wait", "timeout": 500 },
        {
          "action": "screenshot",
          "value": "pcg4-step6-03-gold-visit-limits.png"
        },
        {
          "action": "click",
          "selector": "button:has-text('Authorization')",
          "announce": { "before": "Switching to Authorization tab" }
        },
        { "action": "wait", "timeout": 500 },
        {
          "action": "screenshot",
          "value": "pcg4-step6-04-gold-authorization.png"
        },
        {
          "action": "click",
          "selector": "button:has-text('Exclusions')",
          "announce": { "before": "Switching to Exclusions tab" }
        },
        { "action": "wait", "timeout": 500 },
        {
          "action": "screenshot",
          "value": "pcg4-step6-05-gold-exclusions.png"
        },
        {
          "action": "assertVisible",
          "selector": ":has-text('Total Encounters'), :has-text('Covered'), :has-text('Not Covered'), :has-text('Auth Required')",
          "timeout": 5000,
          "announce": { "after": "Stats bar visible showing coverage totals." }
        },
        {
          "action": "scroll",
          "announce": { "before": "Scrolling to view benefit stats summary" }
        },
        { "action": "wait", "timeout": 500 },
        {
          "action": "screenshot",
          "value": "pcg4-step6-06-stats-bar.png",
          "announce": { "after": "Benefits setup reviewed. Cost sharing tabs and encounter sidebar verified." }
        },
        {
          "action": "click",
          "selector": "button:has-text('Next: Plan Overrides')",
          "announce": { "before": "Proceeding to Step 7 - Plan Overrides" }
        },
        { "action": "wait", "timeout": 2000 }
      ]
    },

    "pcg4-step7-overrides": {
      "name": "Step 7: Plan Specific Overrides",
      "description": "View plan comparison table, configure per-plan general rules, encounter overrides, and regional settings",
      "steps": [
        {
          "action": "assertVisible",
          "selector": "h2:has-text('Plan Specific Overrides')",
          "timeout": 10000,
          "announce": { "before": "Step 7 - Plan Specific Overrides. Comparing Gold vs Silver tier configurations." }
        },
        {
          "action": "assertVisible",
          "selector": "select, label:has-text('Configure Plan')",
          "timeout": 8000,
          "announce": { "after": "Plan selector dropdown visible" }
        },
        {
          "action": "screenshot",
          "value": "pcg4-step7-01-general-rules.png"
        },
        {
          "action": "click",
          "selector": "button:has-text('Encounter Overrides')",
          "announce": { "before": "Switching to Encounter Overrides tab" }
        },
        { "action": "wait", "timeout": 500 },
        {
          "action": "screenshot",
          "value": "pcg4-step7-02-encounter-overrides.png"
        },
        {
          "action": "click",
          "selector": "button:has-text('Regional Settings')",
          "announce": { "before": "Switching to Regional Settings tab" }
        },
        { "action": "wait", "timeout": 500 },
        {
          "action": "screenshot",
          "value": "pcg4-step7-03-regional-settings.png"
        },
        {
          "action": "scroll",
          "announce": { "before": "Scrolling to Plan Comparison Overview table" }
        },
        { "action": "wait", "timeout": 500 },
        {
          "action": "assertVisible",
          "selector": "h3:has-text('Plan Comparison Overview'), table",
          "timeout": 8000,
          "announce": { "after": "Plan Comparison Overview table visible showing Gold and Silver side by side." }
        },
        {
          "action": "screenshot",
          "value": "pcg4-step7-04-plan-comparison.png",
          "announce": { "after": "Plan overrides reviewed. Comparison table shows annual limits, deductibles, OOP max, and coverage counts." }
        },
        {
          "action": "click",
          "selector": "button:has-text('Next: Review')",
          "announce": { "before": "Proceeding to Step 8 - Review and Publish" }
        },
        { "action": "wait", "timeout": 2000 }
      ]
    },

    "pcg4-step8-review": {
      "name": "Step 8: Review & Publish",
      "description": "Review validation status, overview, plan details, encounter summary, and publish settings",
      "steps": [
        {
          "action": "assertVisible",
          "selector": "h2:has-text('Review & Publish')",
          "timeout": 10000,
          "announce": { "before": "Step 8 - Review and Publish. Final validation before publishing." }
        },
        {
          "action": "assertVisible",
          "selector": ":has-text('Validation Status')",
          "timeout": 8000,
          "announce": { "after": "Validation status section visible" }
        },
        {
          "action": "screenshot",
          "value": "pcg4-step8-01-validation.png"
        },
        {
          "action": "assertVisible",
          "selector": "h4:has-text('Insurer Information'), h4:has-text('Product Information')",
          "timeout": 8000,
          "announce": { "after": "Overview tab showing Insurer and Product information cards" }
        },
        {
          "action": "screenshot",
          "value": "pcg4-step8-02-overview.png"
        },
        {
          "action": "click",
          "selector": "button:has-text('plans')",
          "announce": { "before": "Switching to Plans tab" }
        },
        { "action": "wait", "timeout": 500 },
        {
          "action": "screenshot",
          "value": "pcg4-step8-03-plans-detail.png"
        },
        {
          "action": "click",
          "selector": "button:has-text('encounters')",
          "announce": { "before": "Switching to Encounters tab" }
        },
        { "action": "wait", "timeout": 500 },
        {
          "action": "screenshot",
          "value": "pcg4-step8-04-encounters-summary.png"
        },
        {
          "action": "click",
          "selector": "button:has-text('Publish Settings')",
          "announce": { "before": "Switching to Publish Settings tab" }
        },
        { "action": "wait", "timeout": 500 },
        {
          "action": "select",
          "selector": "select",
          "value": "staging",
          "announce": { "after": "Target environment: Staging" }
        },
        {
          "action": "fill",
          "selector": "textarea[placeholder*='notes about this publication']",
          "value": "E2E test configuration for Emirates Health Shield Insurance - Comprehensive Health Plus. Gold and Silver tiers for UAE market. All encounter types enabled for Gold, Inpatient/Outpatient for Silver."
        },
        {
          "action": "screenshot",
          "value": "pcg4-step8-05-publish-settings.png",
          "announce": { "after": "Publish settings configured. Ready for publishing." }
        },
        {
          "action": "assertVisible",
          "selector": "button:has-text('Publish'), button:has-text('Submit for Review'), button:has-text('Save as Draft')",
          "timeout": 5000,
          "announce": { "after": "All action buttons visible: Save as Draft, Submit for Review, Publish." }
        },
        {
          "action": "click",
          "selector": "button:has-text('Publish')",
          "announce": { "before": "Publishing the configuration to staging environment" }
        },
        { "action": "wait", "timeout": 3000 },
        {
          "action": "screenshot",
          "value": "pcg4-step8-06-published.png",
          "announce": { "after": "Configuration published successfully. Emirates Health Shield - Comprehensive Health Plus is now live on staging." }
        }
      ]
    },

    "pcg4-verify-in-list": {
      "name": "Verify Configuration Appears in List",
      "description": "Navigate back to configurations list and verify the new config is present",
      "steps": [
        {
          "action": "navigate",
          "url": "/app/pcg4/configurations",
          "announce": { "before": "Navigating back to configurations list to verify" }
        },
        { "action": "wait", "timeout": 3000 },
        {
          "action": "assertVisible",
          "selector": "td:has-text('Emirates Health Shield'), tr:has-text('Comprehensive Health Plus'), :has-text('EHSI')",
          "timeout": 10000,
          "announce": { "after": "New configuration found in the list. Emirates Health Shield - Comprehensive Health Plus verified." }
        },
        {
          "action": "screenshot",
          "value": "pcg4-verify-01-config-in-list.png"
        }
      ]
    },

    "pcg4-edit-config": {
      "name": "Edit an Existing Configuration",
      "description": "Open the first configuration from the list, verify wizard loads with saved data, check Step 1 prefilled",
      "steps": [
        {
          "action": "navigate",
          "url": "/app/pcg4/configurations",
          "announce": { "before": "Navigating to configurations list for edit test" }
        },
        { "action": "wait", "timeout": 3000 },
        {
          "action": "assertVisible",
          "selector": "table tbody tr",
          "timeout": 10000,
          "announce": { "after": "Configurations table loaded with at least one row" }
        },
        {
          "action": "screenshot",
          "value": "pcg4-edit-01-list-before.png"
        },
        {
          "action": "click",
          "selector": "table tbody tr:first-child button[title='Edit'], table tbody tr:first-child button:has(svg)",
          "announce": { "before": "Clicking Edit on first configuration row" }
        },
        { "action": "wait", "timeout": 3000 },
        {
          "action": "assertVisible",
          "selector": "h2:has-text('Insurer Details')",
          "timeout": 10000,
          "announce": { "after": "Wizard opened in edit mode. Step 1 visible." }
        },
        {
          "action": "assertVisible",
          "selector": "input[placeholder*='Healthy Life Insurance']",
          "timeout": 5000
        },
        {
          "action": "screenshot",
          "value": "pcg4-edit-02-step1-prefilled.png",
          "announce": { "after": "Step 1 loaded with pre-filled insurer data from existing configuration." }
        },
        {
          "action": "click",
          "selector": "button:has-text('Next: Product Details')",
          "announce": { "before": "Advancing to Step 2 to verify product data persistence" }
        },
        { "action": "wait", "timeout": 2000 },
        {
          "action": "assertVisible",
          "selector": "h2:has-text('Product Details')",
          "timeout": 10000
        },
        {
          "action": "screenshot",
          "value": "pcg4-edit-03-step2-prefilled.png",
          "announce": { "after": "Step 2 loaded with pre-filled product details. Data persistence verified across wizard steps." }
        },
        {
          "action": "click",
          "selector": "button:has-text('Next: Create Plans')",
          "announce": { "before": "Advancing to Step 3 to verify plans persistence" }
        },
        { "action": "wait", "timeout": 2000 },
        {
          "action": "assertVisible",
          "selector": "h2:has-text('Create Plans')",
          "timeout": 10000
        },
        {
          "action": "screenshot",
          "value": "pcg4-edit-04-step3-plans-persisted.png",
          "announce": { "after": "Step 3 shows previously created plans. Edit mode data persistence fully verified." }
        }
      ]
    },

    "pcg4-save-draft": {
      "name": "Save Draft at Step 1",
      "description": "Test the Save Draft functionality from Step 1 to verify partial save works",
      "steps": [
        {
          "action": "navigate",
          "url": "/app/pcg4/configurations/new",
          "announce": { "before": "Starting new configuration to test Save Draft" }
        },
        { "action": "wait", "timeout": 2500 },
        {
          "action": "assertVisible",
          "selector": "h2:has-text('Insurer Details')",
          "timeout": 10000
        },
        {
          "action": "fill",
          "selector": "input[placeholder*='Healthy Life Insurance']",
          "value": "Draft Test Insurance Co.",
          "announce": { "before": "Filling partial data for draft save test" }
        },
        {
          "action": "fill",
          "selector": "input[placeholder*='HLI001']",
          "value": "DRAFT-001"
        },
        {
          "action": "fill",
          "selector": "input[placeholder*='REG-HLI-2024-001']",
          "value": "REG-DRAFT-TEST-001"
        },
        {
          "action": "click",
          "selector": "button:has-text('Save Draft')",
          "announce": { "before": "Clicking Save Draft" }
        },
        { "action": "wait", "timeout": 2000 },
        {
          "action": "screenshot",
          "value": "pcg4-draft-01-saved.png",
          "announce": { "after": "Draft saved. Partial insurer data persisted without requiring all fields." }
        }
      ]
    },

    "pcg4-logout": {
      "name": "Logout after PCG4 Test",
      "description": "Safely log out after product configurator testing",
      "steps": [
        {
          "action": "click",
          "selector": "button[class*='avatar'], [data-testid='user-menu'], button[aria-label*='profile']"
        },
        { "action": "wait", "timeout": 800 },
        {
          "action": "click",
          "selector": "button:has-text('Logout'), button:has-text('Sign out'), a:has-text('Logout'), [role='menuitem']:has-text('Log')",
          "announce": { "before": "Logging out" }
        },
        { "action": "wait", "timeout": 2000 },
        {
          "action": "waitForUrl",
          "pattern": "/(login|signin|auth)",
          "timeout": 15000,
          "announce": { "after": "Logged out. PCG4 test session complete." }
        }
      ]
    }
  },


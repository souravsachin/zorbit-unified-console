        "crawl-dashboard",
        "crawl-identity",
        "crawl-authorization",
        "crawl-navigation",
        "crawl-messaging",
        "crawl-audit",
        "crawl-pii-vault",
        "crawl-settings",
        "crawl-admin",
        "crawl-products",
        "crawl-product-pricing",
        "crawl-form-builder",
        "menu-logout"
      ]
    },
    "platform-services-menu": {

{
  "baseUrl": "https://zorbit.scalatics.com",
  "viewport": { "width": 1440, "height": 900 },
  "defaults": {
    "timeout": 12000,
    "waitAfterAction": 800,
    "waitForNetworkIdle": false
  },
  "segments": {
    "menu-login": {
      "name": "Login for Menu Crawl",
      "description": "Authenticate before crawling all menu items",
      "steps": [
        {
          "action": "navigate",
          "url": "/login",
          "announce": { "before": "Logging in for menu sanity test" }
        },
        {
          "action": "wait",
          "timeout": 1500
        },
        {
          "action": "fill",
          "selector": "input[type='email'], input[placeholder*='email' i], input[name='email']",
          "value": "${credentials.admin.email}"
        },
        {
          "action": "fill",
          "selector": "input[type='password']",
          "value": "${credentials.admin.password}"
        },
        {
          "action": "click",
          "selector": "button[type='submit'], button:has-text('Sign in'), button:has-text('Login')"
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "custom",
          "handler": "generateTotp",
          "description": "Generate TOTP for MFA",
          "params": {
            "command": "ssh sovpn 'bash /tmp/get-totp.sh'"
          },
          "selector": "input[inputmode='numeric'], input[maxlength='6'], input[placeholder='000000']"
        },
        {
          "action": "click",
          "selector": "button[type='submit'], button:has-text('Verify')"
        },
        {
          "action": "wait",
          "timeout": 3000
        },
        {
          "action": "waitForUrl",
          "pattern": "/(dashboard|home|app)",
          "timeout": 20000,
          "announce": { "after": "Logged in. Starting menu crawl." }
        }
      ]
    },

    "crawl-dashboard": {
      "name": "Dashboard Menu Item",
      "description": "Click Dashboard in hamburger menu",
      "steps": [
        {
          "action": "click",
          "selector": "button[class*='hamburger'], button[aria-label*='menu'], [data-testid='menu-toggle']",
          "force": true,
          "announce": { "before": "Opening hamburger menu for Dashboard" }
        },
        {
          "action": "wait",
          "timeout": 800
        },
        {
          "action": "click",
          "selector": "a:has-text('Dashboard'), nav a[href*='dashboard']",
          "force": true
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "screenshot",
          "value": "menu-01-dashboard.png",
          "announce": { "after": "Dashboard page loaded" }
        }
      ]
    },


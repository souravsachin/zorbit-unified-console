{
  "baseUrl": "https://zorbit.scalatics.com",
  "viewport": { "width": 1440, "height": 900 },
  "defaults": {
    "timeout": 15000,
    "waitAfterAction": 800,
    "waitForNetworkIdle": false
  },
  "segments": {
    "login-with-mfa": {
      "name": "Login with Email/Password + MFA",
      "description": "Authenticate using email/password then complete TOTP MFA verification",
      "steps": [
        {
          "action": "navigate",
          "url": "/login",
          "announce": { "before": "Navigating to Zorbit login page" }
        },
        {
          "action": "wait",
          "timeout": 1500,
          "announce": { "before": "Waiting for login form to render" }
        },
        {
          "action": "assertVisible",
          "selector": "input[type='email'], input[placeholder*='email' i], input[name='email']",
          "announce": { "after": "Login form is ready" }
        },
        {
          "action": "screenshot",
          "value": "identity-01-login-page.png"
        },
        {
          "action": "fill",
          "selector": "input[type='email'], input[placeholder*='email' i], input[name='email']",
          "value": "${credentials.admin.email}",
          "announce": { "before": "Entering admin email address" }
        },
        {
          "action": "fill",
          "selector": "input[type='password']",
          "value": "${credentials.admin.password}"
        },
        {
          "action": "screenshot",
          "value": "identity-02-login-filled.png"
        },
        {
          "action": "click",
          "selector": "button[type='submit'], button:has-text('Sign in'), button:has-text('Login')",
          "announce": { "after": "Login credentials submitted" }
        },
        {
          "action": "wait",
          "timeout": 2000,
          "announce": { "before": "Waiting for MFA challenge" }
        },
        {
          "action": "screenshot",
          "value": "identity-03-mfa-challenge.png"
        },
        {
          "action": "custom",
          "handler": "generateTotp",
          "description": "Generate TOTP code from server MFA secret",
          "params": {
            "command": "ssh sovpn 'bash /tmp/get-totp.sh'"
          },
          "selector": "input[inputmode='numeric'], input[maxlength='6'], input[placeholder='000000']",
          "announce": { "before": "Generating TOTP code via SSH", "after": "TOTP code entered" }
        },
        {
          "action": "click",
          "selector": "button[type='submit'], button:has-text('Verify'), button:has-text('Confirm')",
          "announce": { "after": "MFA verification submitted" }
        },
        {
          "action": "wait",
          "timeout": 3000
        },
        {
          "action": "waitForUrl",
          "pattern": "/(dashboard|home|app)",
          "timeout": 20000,
          "announce": { "after": "Successfully authenticated with MFA. Welcome to Zorbit." }
        },
        {
          "action": "screenshot",
          "value": "identity-04-post-login.png"
        }
      ]
    },

    "verify-dashboard": {
      "name": "Dashboard Verification",
      "description": "Verify dashboard loads with key metrics: user count, org count, health status",
      "steps": [
        {
          "action": "navigate",
          "url": "/dashboard",
          "announce": { "before": "Navigating to the main dashboard" }
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "assertVisible",
          "selector": "[class*='dashboard'], [data-testid='dashboard'], main",
          "timeout": 10000,
          "announce": { "after": "Dashboard container is visible" }
        },
        {
          "action": "screenshot",
          "value": "identity-05-dashboard-overview.png"
        },
        {
          "action": "assertVisible",
          "selector": "[class*='card'], [class*='stat'], [class*='metric'], [class*='widget']",
          "timeout": 8000,
          "announce": { "after": "Dashboard metric cards are rendering" }
        },
        {
          "action": "scroll",
          "announce": { "before": "Scrolling to see more dashboard widgets" }
        },
        {
          "action": "wait",
          "timeout": 1000
        },
        {
          "action": "screenshot",
          "value": "identity-06-dashboard-scrolled.png",
          "announce": { "after": "Dashboard verified. Metrics and health indicators are visible." }
        }
      ]
    },

    "navigate-to-users": {
      "name": "Navigate to Users via Hamburger Menu",
      "description": "Open hamburger menu, navigate to Identity > Users section",
      "steps": [
        {
          "action": "click",
          "selector": "button[class*='hamburger'], button[aria-label*='menu'], [data-testid='menu-toggle'], button[class*='sidebar-toggle'], .hamburger-menu, button:has(svg[class*='menu'])",
          "force": true,
          "announce": { "before": "Opening the hamburger menu" }
        },
        {
          "action": "wait",
          "timeout": 1000
        },
        {
          "action": "screenshot",
          "value": "identity-07-hamburger-open.png"
        },
        {
          "action": "click",
          "selector": "a:has-text('Identity'), [data-menu='identity'], nav a[href*='identity']",
          "force": true,
          "announce": { "before": "Clicking Identity section in menu" }
        },
        {
          "action": "wait",
          "timeout": 800
        },
        {
          "action": "click",
          "selector": "a:has-text('Users'), [data-menu='users'], nav a[href*='users']",
          "force": true,
          "announce": { "before": "Clicking Users sub-menu item" }
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "waitForUrl",
          "pattern": "/users",
          "timeout": 10000,
          "announce": { "after": "Users page loaded successfully" }
        },
        {
          "action": "screenshot",
          "value": "identity-08-users-list.png"
        }
      ]
    },

    "create-new-user": {
      "name": "Create New User",
      "description": "Create a new user with cascading org/department selector and realistic data",
      "steps": [
        {
          "action": "click",
          "selector": "button:has-text('New User'), button:has-text('Add User'), button:has-text('Create'), a:has-text('New User')",
          "announce": { "before": "Clicking New User button" }
        },
        {
          "action": "wait",
          "timeout": 1500
        },
        {
          "action": "screenshot",
          "value": "identity-09-new-user-form.png"
        },
        {
          "action": "fill",
          "selector": "input[name='firstName'], input[placeholder*='first' i]",
          "value": "Priya",
          "announce": { "before": "Filling in user details: Priya Raghavan, Senior Underwriter" }
        },
        {
          "action": "fill",
          "selector": "input[name='lastName'], input[placeholder*='last' i]",
          "value": "Raghavan"
        },
        {
          "action": "fill",
          "selector": "input[name='email'], input[type='email'], input[placeholder*='email' i]",
          "value": "priya.raghavan@vantara-insurance.com"
        },
        {
          "action": "fill",
          "selector": "input[name='title'], input[placeholder*='title' i], input[placeholder*='job' i]",
          "value": "Senior Underwriter - Health Products"
        },
        {
          "action": "screenshot",
          "value": "identity-10-user-details-filled.png"
        },
        {
          "action": "click",
          "selector": "select[name*='org'], [data-testid*='org-select'], [class*='org-selector'], button:has-text('Select Organization')",
          "announce": { "before": "Selecting organization from cascading dropdown" }
        },
        {
          "action": "wait",
          "timeout": 800
        },
        {
          "action": "click",
          "selector": "[data-value*='vantara'], option:has-text('Vantara'), li:has-text('Vantara'), div:has-text('Vantara General Insurance')",
          "announce": { "after": "Selected Vantara General Insurance" }
        },
        {
          "action": "wait",
          "timeout": 800
        },
        {
          "action": "click",
          "selector": "select[name*='dept'], [data-testid*='dept-select'], [class*='dept-selector'], button:has-text('Select Department')",
          "announce": { "before": "Selecting department" }
        },
        {
          "action": "wait",
          "timeout": 800
        },
        {
          "action": "click",
          "selector": "[data-value*='underwriting'], option:has-text('Underwriting'), li:has-text('Underwriting'), div:has-text('Underwriting')",
          "announce": { "after": "Selected Underwriting department" }
        },
        {
          "action": "screenshot",
          "value": "identity-11-user-org-dept-selected.png"
        },
        {
          "action": "click",
          "selector": "button[type='submit'], button:has-text('Create User'), button:has-text('Save'), button:has-text('Submit')",
          "announce": { "before": "Submitting new user creation" }
        },
        {
          "action": "wait",
          "timeout": 3000
        },
        {
          "action": "screenshot",
          "value": "identity-12-user-created.png",
          "announce": { "after": "User Priya Raghavan created successfully" }
        }
      ]
    },

    "verify-user-in-list": {
      "name": "Verify User in List",
      "description": "Search for the newly created user in the users list",
      "steps": [
        {
          "action": "navigate",
          "url": "/users",
          "announce": { "before": "Going back to users list" }
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "fill",
          "selector": "input[type='search'], input[placeholder*='search' i], input[name='search'], input[class*='search']",
          "value": "Priya",
          "announce": { "before": "Searching for Priya Raghavan in user list" }
        },
        {
          "action": "wait",
          "timeout": 1500
        },
        {
          "action": "assertVisible",
          "selector": "td:has-text('Priya'), tr:has-text('Priya'), [class*='row']:has-text('Priya'), div:has-text('priya.raghavan')",
          "timeout": 10000,
          "announce": { "after": "User Priya Raghavan found in the list. Verification complete." }
        },
        {
          "action": "screenshot",
          "value": "identity-13-user-search-result.png"
        }
      ]
    },

    "navigate-to-organizations": {
      "name": "Navigate to Organizations",
      "description": "Open Organizations page and explore Vantara General Insurance hierarchy",
      "steps": [
        {
          "action": "click",
          "selector": "button[class*='hamburger'], button[aria-label*='menu'], [data-testid='menu-toggle'], button[class*='sidebar-toggle']",
          "force": true,
          "announce": { "before": "Opening hamburger menu for Organizations" }
        },
        {
          "action": "wait",
          "timeout": 800
        },
        {
          "action": "click",
          "selector": "a:has-text('Organizations'), nav a[href*='organization']",
          "force": true,
          "announce": { "before": "Clicking Organizations menu item" }
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "screenshot",
          "value": "identity-14-organizations-list.png",
          "announce": { "after": "Organizations page loaded" }
        },
        {
          "action": "click",
          "selector": "tr:has-text('Vantara'), [class*='row']:has-text('Vantara'), a:has-text('Vantara General Insurance')",
          "announce": { "before": "Opening Vantara General Insurance details" }
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "screenshot",
          "value": "identity-15-vantara-details.png",
          "announce": { "after": "Viewing Vantara General Insurance organization details" }
        }
      ]
    },

    "view-department-hierarchy": {
      "name": "View Department Hierarchy Tree",
      "description": "Navigate through Vantara's department hierarchy tree structure",
      "steps": [
        {
          "action": "click",
          "selector": "a:has-text('Departments'), button:has-text('Departments'), [data-tab='departments'], [role='tab']:has-text('Departments')",
          "announce": { "before": "Switching to Departments tab" }
        },
        {
          "action": "wait",
          "timeout": 1500
        },
        {
          "action": "assertVisible",
          "selector": "[class*='tree'], [class*='hierarchy'], [data-testid='dept-tree'], ul[class*='department']",
          "timeout": 10000,
          "announce": { "after": "Department hierarchy tree is rendering" }
        },
        {
          "action": "screenshot",
          "value": "identity-16-dept-hierarchy.png"
        },
        {
          "action": "click",
          "selector": "[class*='tree-node']:has-text('Underwriting'), [class*='expand']:first-child, li:has-text('Underwriting')",
          "announce": { "before": "Expanding Underwriting department branch" }
        },
        {
          "action": "wait",
          "timeout": 800
        },
        {
          "action": "screenshot",
          "value": "identity-17-dept-underwriting-expanded.png",
          "announce": { "after": "Department hierarchy explored. Underwriting branch expanded." }
        }
      ]
    },

    "view-org-chart": {
      "name": "View Org Chart / Reporting Structure",
      "description": "Navigate to org chart view showing reporting structure",
      "steps": [
        {
          "action": "click",
          "selector": "a:has-text('Org Chart'), button:has-text('Org Chart'), [data-tab='org-chart'], [role='tab']:has-text('Chart'), button:has-text('Reporting')",
          "announce": { "before": "Switching to Org Chart view" }
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "screenshot",
          "value": "identity-18-org-chart.png",
          "announce": { "after": "Org chart loaded. Reporting structure visible." }
        },
        {
          "action": "scroll",
          "announce": { "before": "Scrolling through org chart" }
        },
        {
          "action": "wait",
          "timeout": 800
        },
        {
          "action": "screenshot",
          "value": "identity-19-org-chart-scrolled.png"
        }
      ]
    },

    "navigate-to-security-settings": {
      "name": "Security Settings (MFA, Passkeys, Sessions)",
      "description": "Navigate to Security Settings and review MFA, Passkeys, and Session policies",
      "steps": [
        {
          "action": "click",
          "selector": "button[class*='hamburger'], button[aria-label*='menu'], [data-testid='menu-toggle']",
          "force": true,
          "announce": { "before": "Opening menu for Security Settings" }
        },
        {
          "action": "wait",
          "timeout": 800
        },
        {
          "action": "click",
          "selector": "a:has-text('Settings'), nav a[href*='settings']",
          "force": true
        },
        {
          "action": "wait",
          "timeout": 800
        },
        {
          "action": "click",
          "selector": "a:has-text('Security'), nav a[href*='security']",
          "force": true,
          "announce": { "before": "Navigating to Security Settings" }
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "screenshot",
          "value": "identity-20-security-settings.png",
          "announce": { "after": "Security Settings page loaded" }
        },
        {
          "action": "assertVisible",
          "selector": "[class*='mfa'], :has-text('Multi-Factor'), :has-text('MFA'), [data-section='mfa']",
          "timeout": 8000,
          "announce": { "after": "MFA configuration section is visible" }
        },
        {
          "action": "scroll",
          "selector": ":has-text('Passkeys'), :has-text('FIDO2'), [data-section='passkeys']"
        },
        {
          "action": "wait",
          "timeout": 800
        },
        {
          "action": "screenshot",
          "value": "identity-21-security-passkeys.png",
          "announce": { "after": "Passkeys section visible" }
        },
        {
          "action": "scroll",
          "selector": ":has-text('Sessions'), :has-text('Session Management'), [data-section='sessions']"
        },
        {
          "action": "wait",
          "timeout": 800
        },
        {
          "action": "screenshot",
          "value": "identity-22-security-sessions.png",
          "announce": { "after": "Session management section visible. Security settings review complete." }
        }
      ]
    },

    "scroll-compliance-badges": {
      "name": "Scroll Through Compliance Badges",
      "description": "Scroll through security compliance badges and certifications",
      "steps": [
        {
          "action": "scroll",
          "selector": "[class*='compliance'], [class*='badges'], :has-text('Compliance'), [data-section='compliance']",
          "announce": { "before": "Scrolling to compliance badges section" }
        },
        {
          "action": "wait",
          "timeout": 1000
        },
        {
          "action": "screenshot",
          "value": "identity-23-compliance-badges.png"
        },
        {
          "action": "scroll",
          "announce": { "before": "Scrolling through all compliance certifications" }
        },
        {
          "action": "wait",
          "timeout": 800
        },
        {
          "action": "screenshot",
          "value": "identity-24-compliance-scrolled.png",
          "announce": { "after": "Compliance badges reviewed. SOC2, HIPAA, GDPR indicators visible." }
        }
      ]
    },

    "impersonate-user": {
      "name": "Impersonate a User",
      "description": "Switch to impersonation mode and verify the impersonation banner appears",
      "steps": [
        {
          "action": "click",
          "selector": "button[class*='hamburger'], button[aria-label*='menu'], [data-testid='menu-toggle']",
          "force": true,
          "announce": { "before": "Opening menu to navigate to Users for impersonation" }
        },
        {
          "action": "wait",
          "timeout": 800
        },
        {
          "action": "click",
          "selector": "a:has-text('Users'), nav a[href*='users']",
          "force": true
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "click",
          "selector": "tr:first-child button[aria-label*='actions'], tr:first-child [class*='action'], tr:nth-child(2) button:has-text('...'), tr:nth-child(2) [class*='dropdown-trigger']",
          "announce": { "before": "Opening actions menu on a user row" }
        },
        {
          "action": "wait",
          "timeout": 800
        },
        {
          "action": "click",
          "selector": "button:has-text('Impersonate'), [data-action='impersonate'], a:has-text('Impersonate'), [role='menuitem']:has-text('Impersonate')",
          "announce": { "before": "Clicking Impersonate button" }
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "screenshot",
          "value": "identity-25-impersonation-active.png"
        },
        {
          "action": "assertVisible",
          "selector": "[class*='impersonat'], [data-testid='impersonation-banner'], [class*='banner']:has-text('Impersonat'), div:has-text('impersonating')",
          "timeout": 10000,
          "announce": { "after": "Impersonation banner is visible. You are now viewing the console as another user." }
        }
      ]
    },

    "exit-impersonation": {
      "name": "Exit Impersonation",
      "description": "Exit impersonation mode and return to admin view",
      "steps": [
        {
          "action": "click",
          "selector": "button:has-text('Exit'), button:has-text('Stop Impersonating'), [data-action='exit-impersonation'], [class*='impersonat'] button",
          "announce": { "before": "Exiting impersonation mode" }
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "screenshot",
          "value": "identity-26-impersonation-exited.png",
          "announce": { "after": "Impersonation exited. Back to admin view." }
        }
      ]
    },

    "logout": {
      "name": "Logout",
      "description": "Safely log out of the Zorbit platform",
      "steps": [
        {
          "action": "click",
          "selector": "button[class*='avatar'], [data-testid='user-menu'], button[aria-label*='profile'], [class*='user-avatar'], img[class*='avatar']",
          "announce": { "before": "Opening user profile menu" }
        },
        {
          "action": "wait",
          "timeout": 800
        },
        {
          "action": "screenshot",
          "value": "identity-27-user-menu.png"
        },
        {
          "action": "click",
          "selector": "button:has-text('Logout'), button:has-text('Sign out'), a:has-text('Logout'), [data-action='logout'], [role='menuitem']:has-text('Log')",
          "announce": { "before": "Clicking Logout" }
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "waitForUrl",
          "pattern": "/(login|signin|auth)",
          "timeout": 15000,
          "announce": { "after": "Successfully logged out. Returned to login page." }
        },
        {
          "action": "screenshot",
          "value": "identity-28-logged-out.png"
        }
      ]
    }
  },

  "journeys": {
    "full-identity-flow": {
      "name": "Complete Identity Service Flow",
      "description": "End-to-end identity service test: login with MFA, dashboard, users, orgs, security, impersonation, logout",
      "segments": [
        "login-with-mfa",
        "verify-dashboard",
        "navigate-to-users",
        "create-new-user",
        "verify-user-in-list",
        "navigate-to-organizations",
        "view-department-hierarchy",
        "view-org-chart",
        "navigate-to-security-settings",
        "scroll-compliance-badges",
        "impersonate-user",
        "exit-impersonation",
        "logout"
      ]
    },
    "login-and-dashboard": {
      "name": "Login + Dashboard Only",
      "description": "Quick verification of login and dashboard",
      "segments": [
        "login-with-mfa",
        "verify-dashboard",
        "logout"
      ]
    },
    "user-management": {
      "name": "User Management Flow",
      "description": "Login, create user, verify user, manage impersonation",
      "segments": [
        "login-with-mfa",
        "navigate-to-users",
        "create-new-user",
        "verify-user-in-list",
        "impersonate-user",
        "exit-impersonation",
        "logout"
      ]
    },
    "org-hierarchy-review": {
      "name": "Organization Hierarchy Review",
      "description": "Login and explore org/department hierarchy and org chart",
      "segments": [
        "login-with-mfa",
        "navigate-to-organizations",
        "view-department-hierarchy",
        "view-org-chart",
        "logout"
      ]
    }
  },

  "bouquets": {
    "identity-full": {
      "name": "Identity Service - Full Suite",
      "description": "Complete identity service regression test covering all capabilities",
      "mode": "sequential",
      "journeys": ["full-identity-flow"]
    },
    "identity-quick": {
      "name": "Identity Service - Quick Check",
      "description": "Fast login and dashboard verification",
      "mode": "sequential",
      "journeys": ["login-and-dashboard"]
    },
    "identity-management": {
      "name": "Identity Service - Management Suite",
      "description": "User and org management flows",
      "mode": "sequential",
      "journeys": ["user-management", "org-hierarchy-review"]
    }
  }
}

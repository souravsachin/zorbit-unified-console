  "journeys": {
    "identity-login-and-dashboard": {
      "name": "Login + Dashboard Only",
      "description": "Quick verification of login and dashboard (no MFA)",
      "segments": [
        "identity-login",
        "identity-verify-dashboard",
        "identity-logout"
      ]
    },
    "identity-mfa-flow": {
      "name": "MFA Setup and Login",
      "description": "Enable MFA in security settings, then verify MFA login works",
      "segments": [
        "identity-login",
        "identity-mfa-setup",
        "identity-logout",
        "identity-mfa-login",
        "identity-verify-dashboard",
        "identity-logout"
      ]
    },
    "identity-user-management": {
      "name": "User Management Flow",
      "description": "Login, create user, verify user, assign roles, impersonate",
      "segments": [
        "identity-login",
        "identity-navigate-users",
        "identity-create-user",
        "identity-verify-user-in-list",
        "identity-user-roles",
        "identity-impersonation",
        "identity-exit-impersonation",
        "identity-logout"
      ]
    },
    "identity-org-management": {
      "name": "Organization & Department Management",
      "description": "Create org, create department, view hierarchy and org chart",
      "segments": [
        "identity-login",
        "identity-navigate-organizations",
        "identity-create-org",
        "identity-create-department",
        "identity-view-department-hierarchy",
        "identity-org-chart",
        "identity-logout"
      ]
    },
    "identity-security-review": {
      "name": "Security Settings Review",
      "description": "Review all security settings: MFA, Passkeys, Sessions, Geo-Restriction",
      "segments": [
        "identity-login",
        "identity-security-settings",
        "identity-compliance-badges",
        "identity-logout"
      ]
    },
    "identity-full-regression": {
      "name": "Complete Identity Service Regression",
      "description": "End-to-end regression covering all identity features",
      "segments": [
        "identity-login-mfa",
        "identity-verify-dashboard",
        "identity-navigate-users",
        "identity-create-user",
        "identity-verify-user-in-list",
        "identity-user-roles",
        "identity-navigate-organizations",
        "identity-create-org",
        "identity-create-department",
        "identity-view-department-hierarchy",
        "identity-org-chart",
        "identity-security-settings",
        "identity-compliance-badges",
        "identity-impersonation",
        "identity-exit-impersonation",
        "identity-logout"
      ]
    }
  },

  "bouquets": {
    "identity-quick": {
      "name": "Identity Service - Quick Check",
      "description": "Fast login and dashboard verification (under 1 minute)",
      "mode": "sequential",
      "journeys": ["identity-login-and-dashboard"]
    },
    "identity-full": {
      "name": "Identity Service - Full Suite",
      "description": "Complete identity regression: MFA, org creation, user management, security, impersonation",
      "mode": "sequential",
      "journeys": ["identity-full-regression"]
    },
    "identity-security": {
      "name": "Identity Service - Security Suite",
      "description": "MFA setup, MFA login verification, and security settings review",
      "mode": "sequential",
      "journeys": ["identity-mfa-flow", "identity-security-review"]
    },
    "identity-management": {
      "name": "Identity Service - Management Suite",
      "description": "User and organization management flows",
      "mode": "sequential",
      "journeys": ["identity-user-management", "identity-org-management"]
    }
  }
}

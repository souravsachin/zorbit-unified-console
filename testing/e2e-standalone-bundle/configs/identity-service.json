{
  "baseUrl": "https://zorbit.scalatics.com",
  "viewport": { "width": 1440, "height": 900 },
  "defaults": {
    "timeout": 15000,
    "waitAfterAction": 800,
    "waitForNetworkIdle": false
  },
  "segments": {
    "identity-login": {
      "name": "Login with Email/Password (no MFA)",
      "description": "Quick login for accounts without MFA enabled",
      "steps": [
        {
          "action": "navigate",
          "url": "/login",
          "announce": { "before": "Navigating to Zorbit login page" }
        },
        {
          "action": "wait",
          "timeout": 1500,
          "announce": { "before": "Waiting for login form to render" }
        },
        {
          "action": "assertVisible",
          "selector": "input[type='email'], input[placeholder*='email' i], input[name='email']",
          "announce": { "after": "Login form is ready" }
        },
        {
          "action": "screenshot",
          "value": "identity-login-01-page.png"
        },
        {
          "action": "fill",
          "selector": "input[type='email'], input[placeholder*='email' i], input[name='email']",
          "value": "${credentials.admin.email}",
          "announce": { "before": "Entering admin email address" }
        },
        {
          "action": "fill",
          "selector": "input[type='password']",
          "value": "${credentials.admin.password}"
        },
        {
          "action": "screenshot",
          "value": "identity-login-02-filled.png"
        },
        {
          "action": "click",
          "selector": "button[type='submit'], button:has-text('Sign in'), button:has-text('Login')",
          "announce": { "after": "Login credentials submitted" }
        },
        {
          "action": "wait",
          "timeout": 3000
        },
        {
          "action": "waitForUrl",
          "pattern": "/(dashboard|home|app)",
          "timeout": 20000,
          "announce": { "after": "Successfully authenticated. Welcome to Zorbit." }
        },
        {
          "action": "screenshot",
          "value": "identity-login-03-post-login.png"
        }
      ]
    },

    "identity-login-mfa": {
      "name": "Login with Email/Password + MFA",
      "description": "Authenticate using email/password then complete TOTP MFA verification",
      "steps": [
        {
          "action": "navigate",
          "url": "/login",
          "announce": { "before": "Navigating to Zorbit login page" }
        },
        {
          "action": "wait",
          "timeout": 1500,
          "announce": { "before": "Waiting for login form to render" }
        },
        {
          "action": "assertVisible",
          "selector": "input[type='email'], input[placeholder*='email' i], input[name='email']",
          "announce": { "after": "Login form is ready" }
        },
        {
          "action": "screenshot",
          "value": "identity-mfa-login-01-page.png"
        },
        {
          "action": "fill",
          "selector": "input[type='email'], input[placeholder*='email' i], input[name='email']",
          "value": "${credentials.admin.email}",
          "announce": { "before": "Entering admin email address" }
        },
        {
          "action": "fill",
          "selector": "input[type='password']",
          "value": "${credentials.admin.password}"
        },
        {
          "action": "screenshot",
          "value": "identity-mfa-login-02-filled.png"
        },
        {
          "action": "click",
          "selector": "button[type='submit'], button:has-text('Sign in'), button:has-text('Login')",
          "announce": { "after": "Login credentials submitted" }
        },
        {
          "action": "wait",
          "timeout": 2000,
          "announce": { "before": "Waiting for MFA challenge" }
        },
        {
          "action": "screenshot",
          "value": "identity-mfa-login-03-challenge.png"
        },
        {
          "action": "custom",
          "handler": "generateTotp",
          "description": "Generate TOTP code from server MFA secret",
          "params": {
            "command": "ssh sovpn 'bash /tmp/get-totp.sh'"
          },
          "selector": "input[inputmode='numeric'], input[maxlength='6'], input[placeholder='000000']",
          "announce": { "before": "Generating TOTP code via SSH", "after": "TOTP code entered" }
        },
        {
          "action": "click",
          "selector": "button[type='submit'], button:has-text('Verify'), button:has-text('Confirm')",
          "announce": { "after": "MFA verification submitted" }
        },
        {
          "action": "wait",
          "timeout": 3000
        },
        {
          "action": "waitForUrl",
          "pattern": "/(dashboard|home|app)",
          "timeout": 20000,
          "announce": { "after": "Successfully authenticated with MFA. Welcome to Zorbit." }
        },
        {
          "action": "screenshot",
          "value": "identity-mfa-login-04-post-login.png"
        }
      ]
    },

    "identity-verify-dashboard": {
      "name": "Dashboard Verification",
      "description": "Verify dashboard loads with key metrics: user count, org count, health status",
      "steps": [
        {
          "action": "navigate",
          "url": "/dashboard",
          "announce": { "before": "Navigating to the main dashboard" }
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "assertVisible",
          "selector": "[class*='dashboard'], [data-testid='dashboard'], main",
          "timeout": 10000,
          "announce": { "after": "Dashboard container is visible" }
        },
        {
          "action": "screenshot",
          "value": "identity-dashboard-01-overview.png"
        },
        {
          "action": "assertVisible",
          "selector": "[class*='card'], [class*='stat'], [class*='metric'], [class*='widget']",
          "timeout": 8000,
          "announce": { "after": "Dashboard metric cards are rendering" }
        },
        {
          "action": "scroll",
          "announce": { "before": "Scrolling to see more dashboard widgets" }
        },
        {
          "action": "wait",
          "timeout": 1000
        },
        {
          "action": "screenshot",
          "value": "identity-dashboard-02-scrolled.png",
          "announce": { "after": "Dashboard verified. Metrics and health indicators are visible." }
        }
      ]
    },

    "identity-mfa-setup": {
      "name": "Enable MFA via Settings > Security",
      "description": "Navigate to Security settings and enable TOTP-based MFA with QR code and backup codes",
      "steps": [
        {
          "action": "navigate",
          "url": "/settings/security",
          "announce": { "before": "Navigating to Settings > Security page" }
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "assertVisible",
          "selector": "h1:has-text('Security'), h2:has-text('Security')",
          "timeout": 10000,
          "announce": { "after": "Security page loaded" }
        },
        {
          "action": "screenshot",
          "value": "identity-mfa-setup-01-security-page.png"
        },
        {
          "action": "assertVisible",
          "selector": "button:has-text('Enable MFA'), button:has-text('Set Up MFA'), button:has-text('Enable Two-Factor'), [data-testid='enable-mfa']",
          "timeout": 8000,
          "announce": { "after": "MFA enable button is visible" }
        },
        {
          "action": "click",
          "selector": "button:has-text('Enable MFA'), button:has-text('Set Up MFA'), button:has-text('Enable Two-Factor'), [data-testid='enable-mfa']",
          "announce": { "before": "Clicking Enable MFA button" }
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "assertVisible",
          "selector": "img[alt*='QR'], img[src*='data:image'], canvas, [class*='qr'], [data-testid='qr-code']",
          "timeout": 10000,
          "announce": { "after": "QR code is displayed for authenticator app scanning" }
        },
        {
          "action": "screenshot",
          "value": "identity-mfa-setup-02-qr-code.png"
        },
        {
          "action": "assertVisible",
          "selector": "code, [class*='secret'], [data-testid='mfa-secret'], span:has-text('otpauth')",
          "timeout": 5000,
          "announce": { "after": "TOTP secret key is visible for manual entry" }
        },
        {
          "action": "scroll",
          "announce": { "before": "Scrolling to see backup codes" }
        },
        {
          "action": "wait",
          "timeout": 1000
        },
        {
          "action": "assertVisible",
          "selector": "[class*='backup'], :has-text('Backup Codes'), :has-text('Recovery'), [data-testid='backup-codes']",
          "timeout": 5000,
          "announce": { "after": "Backup codes section is visible" }
        },
        {
          "action": "screenshot",
          "value": "identity-mfa-setup-03-backup-codes.png"
        },
        {
          "action": "click",
          "selector": "input[type='checkbox'], label:has-text('saved'), label:has-text('acknowledge'), label:has-text('backed up')",
          "announce": { "before": "Acknowledging backup codes have been saved" }
        },
        {
          "action": "wait",
          "timeout": 500
        },
        {
          "action": "custom",
          "handler": "generateTotp",
          "description": "Generate TOTP code from the displayed secret to verify setup",
          "params": {
            "command": "ssh sovpn 'bash /tmp/get-totp.sh'"
          },
          "selector": "input[inputmode='numeric'], input[maxlength='6'], input[placeholder='000000'], input[name='code'], input[placeholder*='code' i]",
          "announce": { "before": "Generating TOTP code to verify MFA setup", "after": "TOTP verification code entered" }
        },
        {
          "action": "click",
          "selector": "button:has-text('Verify'), button:has-text('Confirm'), button:has-text('Enable'), button[type='submit']",
          "announce": { "before": "Submitting verification code to finalize MFA setup" }
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "screenshot",
          "value": "identity-mfa-setup-04-enabled.png",
          "announce": { "after": "MFA has been successfully enabled. TOTP verification passed." }
        }
      ]
    },

    "identity-mfa-login": {
      "name": "Login with MFA Verification",
      "description": "Login flow that includes TOTP MFA challenge after credential submission",
      "steps": [
        {
          "action": "navigate",
          "url": "/login",
          "announce": { "before": "Navigating to login page for MFA login test" }
        },
        {
          "action": "wait",
          "timeout": 1500
        },
        {
          "action": "fill",
          "selector": "input[type='email'], input[placeholder*='email' i], input[name='email']",
          "value": "${credentials.admin.email}",
          "announce": { "before": "Entering admin email for MFA login" }
        },
        {
          "action": "fill",
          "selector": "input[type='password']",
          "value": "${credentials.admin.password}"
        },
        {
          "action": "click",
          "selector": "button[type='submit'], button:has-text('Sign in'), button:has-text('Login')",
          "announce": { "after": "Credentials submitted, waiting for MFA challenge" }
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "assertVisible",
          "selector": "input[inputmode='numeric'], input[maxlength='6'], input[placeholder='000000'], :has-text('verification code'), :has-text('Enter the code')",
          "timeout": 10000,
          "announce": { "after": "MFA challenge screen is displayed" }
        },
        {
          "action": "screenshot",
          "value": "identity-mfa-login-01-challenge.png"
        },
        {
          "action": "custom",
          "handler": "generateTotp",
          "description": "Generate TOTP code from server MFA secret",
          "params": {
            "command": "ssh sovpn 'bash /tmp/get-totp.sh'"
          },
          "selector": "input[inputmode='numeric'], input[maxlength='6'], input[placeholder='000000']",
          "announce": { "before": "Generating TOTP code via SSH", "after": "TOTP code entered into MFA field" }
        },
        {
          "action": "click",
          "selector": "button[type='submit'], button:has-text('Verify'), button:has-text('Confirm')",
          "announce": { "before": "Submitting MFA verification code" }
        },
        {
          "action": "wait",
          "timeout": 3000
        },
        {
          "action": "waitForUrl",
          "pattern": "/(dashboard|home|app)",
          "timeout": 20000,
          "announce": { "after": "MFA login completed. Dashboard loaded." }
        },
        {
          "action": "screenshot",
          "value": "identity-mfa-login-02-success.png"
        }
      ]
    },

    "identity-navigate-users": {
      "name": "Navigate to Users via Hamburger Menu",
      "description": "Open hamburger menu, navigate to Identity > Users section",
      "steps": [
        {
          "action": "click",
          "selector": "button[class*='hamburger'], button[aria-label*='menu'], [data-testid='menu-toggle'], button[class*='sidebar-toggle'], .hamburger-menu, button:has(svg[class*='menu'])",
          "force": true,
          "announce": { "before": "Opening the hamburger menu" }
        },
        {
          "action": "wait",
          "timeout": 1000
        },
        {
          "action": "screenshot",
          "value": "identity-nav-users-01-menu-open.png"
        },
        {
          "action": "click",
          "selector": "a:has-text('Identity'), [data-menu='identity'], nav a[href*='identity']",
          "force": true,
          "announce": { "before": "Clicking Identity section in menu" }
        },
        {
          "action": "wait",
          "timeout": 800
        },
        {
          "action": "click",
          "selector": "a:has-text('Users'), [data-menu='users'], nav a[href*='users']",
          "force": true,
          "announce": { "before": "Clicking Users sub-menu item" }
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "waitForUrl",
          "pattern": "/users",
          "timeout": 10000,
          "announce": { "after": "Users page loaded successfully" }
        },
        {
          "action": "screenshot",
          "value": "identity-nav-users-02-list.png"
        }
      ]
    },

    "identity-create-user": {
      "name": "Create New User",
      "description": "Create a new user with cascading org/department selector and realistic data",
      "steps": [
        {
          "action": "click",
          "selector": "button:has-text('Create User'), button:has-text('New User'), button:has-text('Add User')",
          "announce": { "before": "Clicking Create User button" }
        },
        {
          "action": "wait",
          "timeout": 1500
        },
        {
          "action": "assertVisible",
          "selector": "[class*='modal'], [role='dialog']",
          "timeout": 5000,
          "announce": { "after": "Create User modal is open" }
        },
        {
          "action": "screenshot",
          "value": "identity-create-user-01-modal.png"
        },
        {
          "action": "click",
          "selector": "select:has(option:has-text('Select organization')), select:has(option:has-text('-- Select organization --'))",
          "announce": { "before": "Opening organization selector" }
        },
        {
          "action": "wait",
          "timeout": 800
        },
        {
          "action": "select",
          "selector": "select:has(option:has-text('Select organization')), select:has(option:has-text('-- Select organization --'))",
          "value": "${testData.organizationHashId}",
          "announce": { "after": "Selected target organization" }
        },
        {
          "action": "wait",
          "timeout": 1000,
          "announce": { "before": "Waiting for department hierarchy to load" }
        },
        {
          "action": "fill",
          "selector": "input[name='displayName'], input:near(label:has-text('Display Name'))",
          "value": "Priya Raghavan",
          "announce": { "before": "Filling in user details: Priya Raghavan, Senior Underwriter" }
        },
        {
          "action": "fill",
          "selector": "input[type='email'], input[name='email']",
          "value": "priya.raghavan@vantara-insurance.com"
        },
        {
          "action": "screenshot",
          "value": "identity-create-user-02-details-filled.png"
        },
        {
          "action": "click",
          "selector": "select:has(option:has-text('Select a role')), select:has(option:has-text('-- Select a role --'))",
          "announce": { "before": "Selecting a role for the new user" }
        },
        {
          "action": "wait",
          "timeout": 500
        },
        {
          "action": "screenshot",
          "value": "identity-create-user-03-role-selected.png"
        },
        {
          "action": "click",
          "selector": "button[type='submit']:has-text('Create User'), button[type='submit']:has-text('Create')",
          "announce": { "before": "Submitting new user creation" }
        },
        {
          "action": "wait",
          "timeout": 3000
        },
        {
          "action": "screenshot",
          "value": "identity-create-user-04-created.png",
          "announce": { "after": "User Priya Raghavan created successfully" }
        }
      ]
    },

    "identity-verify-user-in-list": {
      "name": "Verify User in List",
      "description": "Search for the newly created user in the users list",
      "steps": [
        {
          "action": "navigate",
          "url": "/users",
          "announce": { "before": "Going back to users list" }
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "fill",
          "selector": "input[type='search'], input[placeholder*='search' i], input[name='search'], input[class*='search']",
          "value": "Priya",
          "announce": { "before": "Searching for Priya Raghavan in user list" }
        },
        {
          "action": "wait",
          "timeout": 1500
        },
        {
          "action": "assertVisible",
          "selector": "td:has-text('Priya'), tr:has-text('Priya'), [class*='row']:has-text('Priya'), div:has-text('priya.raghavan')",
          "timeout": 10000,
          "announce": { "after": "User Priya Raghavan found in the list. Verification complete." }
        },
        {
          "action": "screenshot",
          "value": "identity-verify-user-01-search-result.png"
        }
      ]
    },

    "identity-user-roles": {
      "name": "Assign Role to User",
      "description": "Open the Assign Role modal on a user and assign a role via the authorization service",
      "steps": [
        {
          "action": "navigate",
          "url": "/users",
          "announce": { "before": "Navigating to Users page for role assignment" }
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "assertVisible",
          "selector": "h1:has-text('Users')",
          "timeout": 10000,
          "announce": { "after": "Users page loaded" }
        },
        {
          "action": "screenshot",
          "value": "identity-user-roles-01-users-list.png"
        },
        {
          "action": "click",
          "selector": "tr:nth-child(2) button[title='Assign role'], tr:nth-child(2) button:has(svg.text-blue-500), table tbody tr:nth-child(2) .flex.gap-1 button:nth-child(2)",
          "announce": { "before": "Clicking Assign Role (shield icon) on the second user row" }
        },
        {
          "action": "wait",
          "timeout": 1000
        },
        {
          "action": "assertVisible",
          "selector": "[class*='modal'], [role='dialog']",
          "timeout": 5000,
          "announce": { "after": "Assign Role modal is open" }
        },
        {
          "action": "screenshot",
          "value": "identity-user-roles-02-assign-modal.png"
        },
        {
          "action": "assertVisible",
          "selector": "select:has(option:has-text('Select a role'))",
          "timeout": 5000,
          "announce": { "after": "Role dropdown is visible with available roles" }
        },
        {
          "action": "click",
          "selector": "select:has(option:has-text('Select a role'))",
          "announce": { "before": "Opening role selector dropdown" }
        },
        {
          "action": "wait",
          "timeout": 500
        },
        {
          "action": "screenshot",
          "value": "identity-user-roles-03-role-dropdown.png"
        },
        {
          "action": "click",
          "selector": "button:has-text('Cancel'), button.btn-secondary",
          "announce": { "after": "Closed Assign Role modal without changes (read-only test)" }
        },
        {
          "action": "screenshot",
          "value": "identity-user-roles-04-closed.png"
        }
      ]
    },

    "identity-create-org": {
      "name": "Create a New Organization",
      "description": "Navigate to Organizations page and create a new organization with type selector",
      "steps": [
        {
          "action": "navigate",
          "url": "/organizations",
          "announce": { "before": "Navigating to Organizations page" }
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "assertVisible",
          "selector": "h1:has-text('Organizations')",
          "timeout": 10000,
          "announce": { "after": "Organizations page loaded" }
        },
        {
          "action": "screenshot",
          "value": "identity-create-org-01-list.png"
        },
        {
          "action": "click",
          "selector": "button:has-text('Create Organization')",
          "announce": { "before": "Clicking Create Organization button" }
        },
        {
          "action": "wait",
          "timeout": 1000
        },
        {
          "action": "assertVisible",
          "selector": "[class*='modal'], [role='dialog']",
          "timeout": 5000,
          "announce": { "after": "Create Organization modal is open" }
        },
        {
          "action": "screenshot",
          "value": "identity-create-org-02-modal.png"
        },
        {
          "action": "fill",
          "selector": "input.input-field, input:near(label:has-text('Name'))",
          "value": "Meridian Health Partners",
          "announce": { "before": "Entering organization name: Meridian Health Partners" }
        },
        {
          "action": "click",
          "selector": "select.input-field, select:near(label:has-text('Organization Type'))",
          "announce": { "before": "Opening organization type selector" }
        },
        {
          "action": "wait",
          "timeout": 500
        },
        {
          "action": "select",
          "selector": "select.input-field, select:near(label:has-text('Organization Type'))",
          "value": "Healthcare Provider",
          "announce": { "after": "Selected Healthcare Provider as organization type" }
        },
        {
          "action": "screenshot",
          "value": "identity-create-org-03-filled.png"
        },
        {
          "action": "click",
          "selector": "button[type='submit']:has-text('Create'), button.btn-primary:has-text('Create')",
          "announce": { "before": "Submitting organization creation" }
        },
        {
          "action": "wait",
          "timeout": 3000
        },
        {
          "action": "screenshot",
          "value": "identity-create-org-04-created.png",
          "announce": { "after": "Organization Meridian Health Partners created successfully" }
        },
        {
          "action": "assertVisible",
          "selector": "td:has-text('Meridian'), tr:has-text('Meridian'), div:has-text('Meridian Health Partners')",
          "timeout": 10000,
          "announce": { "after": "New organization appears in the list" }
        }
      ]
    },

    "identity-create-department": {
      "name": "Create Department Within Organization",
      "description": "Navigate to an organization's departments page and create a new department",
      "steps": [
        {
          "action": "navigate",
          "url": "/organizations",
          "announce": { "before": "Navigating to Organizations to find target org" }
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "click",
          "selector": "a:has-text('Depts'), a[href*='/departments']:first-of-type, tr:first-child a:has-text('Depts')",
          "announce": { "before": "Clicking Depts link on the first organization row" }
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "assertVisible",
          "selector": "h1:has-text('Departments')",
          "timeout": 10000,
          "announce": { "after": "Departments page loaded with hierarchy tree" }
        },
        {
          "action": "screenshot",
          "value": "identity-create-dept-01-page.png"
        },
        {
          "action": "click",
          "selector": "button:has-text('Add Department')",
          "announce": { "before": "Clicking Add Department button" }
        },

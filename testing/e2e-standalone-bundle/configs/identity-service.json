    "identity-impersonation": {
      "name": "Impersonate a User",
      "description": "Use the impersonation feature (eye icon) on a user to switch context and verify the impersonation banner",
      "steps": [
        {
          "action": "navigate",
          "url": "/users",
          "announce": { "before": "Navigating to Users page for impersonation test" }
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "assertVisible",
          "selector": "h1:has-text('Users')",
          "timeout": 10000
        },
        {
          "action": "screenshot",
          "value": "identity-impersonate-01-users.png"
        },
        {
          "action": "click",
          "selector": "tr:nth-child(2) button[title='View as this user'], tr:nth-child(2) button:has(svg.text-purple-500), table tbody tr:nth-child(2) .flex.gap-1 button:first-child",
          "announce": { "before": "Clicking impersonate (eye icon) on the second user row" }
        },
        {
          "action": "wait",
          "timeout": 1000
        },
        {
          "action": "click",
          "selector": "button:has-text('OK'), button:has-text('Confirm')",

{
  "baseUrl": "https://zorbit.scalatics.com",
  "viewport": { "width": 1440, "height": 900 },
  "defaults": {
    "timeout": 15000,
    "waitAfterAction": 800,
    "waitForNetworkIdle": false
  },

  "segments": {

    "logout": {
      "name": "Logout of Zorbit",
      "description": "Click avatar menu, logout, verify login page appears",
      "steps": [
        {
          "action": "click",
          "selector": "button[class*='avatar'], [data-testid='user-menu'], button[aria-label*='profile'], [class*='user-avatar'], img[class*='avatar']",
          "announce": { "before": "Opening user profile menu to logout" }
        },
        {
          "action": "wait",
          "timeout": 800
        },
        {
          "action": "screenshot",
          "value": "awnic-logout-01-menu.png"
        },
        {
          "action": "click",
          "selector": "button:has-text('Logout'), button:has-text('Sign out'), a:has-text('Logout'), [data-action='logout'], [role='menuitem']:has-text('Log')",
          "announce": { "before": "Clicking Logout" }
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "waitForUrl",
          "pattern": "/(login|signin|auth)",
          "timeout": 15000,
          "announce": { "after": "Logged out successfully. Login page visible." }
        },
        {
          "action": "screenshot",
          "value": "awnic-logout-02-login-page.png"
        }
      ]
    },

    "login": {
      "name": "Login to Zorbit",
      "description": "Login with admin credentials, handle MFA if prompted, verify dashboard loads",
      "steps": [
        {
          "action": "navigate",
          "url": "/login",
          "announce": { "before": "Navigating to Zorbit login page" }
        },
        {
          "action": "wait",
          "timeout": 1500
        },
        {
          "action": "assertVisible",
          "selector": "input[type='email'], input[placeholder*='email' i], input[name='email']",
          "announce": { "after": "Login form is ready" }
        },
        {
          "action": "screenshot",
          "value": "awnic-login-01-form.png"
        },
        {
          "action": "fill",
          "selector": "input[type='email'], input[placeholder*='email' i], input[name='email']",
          "value": "${credentials.admin.email}",
          "announce": { "before": "Entering admin email" }
        },
        {
          "action": "fill",
          "selector": "input[type='password']",
          "value": "${credentials.admin.password}"
        },
        {
          "action": "screenshot",
          "value": "awnic-login-02-filled.png"
        },
        {
          "action": "click",
          "selector": "button[type='submit'], button:has-text('Sign in'), button:has-text('Login')",
          "announce": { "after": "Login credentials submitted" }
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "custom",
          "handler": "generateTotp",
          "description": "Generate TOTP for MFA if challenged",
          "params": {
            "command": "ssh sovpn 'bash /tmp/get-totp.sh'"
          },
          "selector": "input[inputmode='numeric'], input[maxlength='6'], input[placeholder='000000']",
          "announce": { "before": "Generating TOTP code via SSH", "after": "TOTP code entered" }
        },
        {
          "action": "click",
          "selector": "button[type='submit'], button:has-text('Verify'), button:has-text('Confirm')"
        },
        {
          "action": "wait",
          "timeout": 3000
        },
        {
          "action": "waitForUrl",
          "pattern": "/(dashboard|home|app)",
          "timeout": 20000,
          "announce": { "after": "Successfully logged in to Zorbit" }
        },
        {
          "action": "screenshot",
          "value": "awnic-login-03-dashboard.png"
        }
      ]
    },

    "enable-mfa": {
      "name": "Enable MFA via Settings",
      "description": "Navigate to Settings > Security and enable TOTP-based MFA",
      "steps": [
        {
          "action": "click",
          "selector": "button[class*='hamburger'], button[aria-label*='menu'], [data-testid='menu-toggle']",
          "force": true,
          "announce": { "before": "Opening menu to navigate to Settings" }
        },
        {
          "action": "wait",
          "timeout": 800
        },
        {
          "action": "click",
          "selector": "a:has-text('Settings'), nav a[href*='settings']",
          "force": true,
          "announce": { "before": "Clicking Settings" }
        },
        {
          "action": "wait",
          "timeout": 1000
        },
        {
          "action": "click",
          "selector": "a:has-text('Security'), nav a[href*='security'], [data-tab='security'], [role='tab']:has-text('Security')",
          "force": true,
          "announce": { "before": "Navigating to Security tab" }
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "screenshot",
          "value": "awnic-mfa-01-security-settings.png"
        },
        {
          "action": "assertVisible",
          "selector": "[class*='mfa'], :has-text('Multi-Factor'), :has-text('MFA'), [data-section='mfa']",
          "timeout": 8000,
          "announce": { "after": "MFA configuration section is visible" }
        },
        {
          "action": "click",
          "selector": "button:has-text('Enable MFA'), button:has-text('Enable TOTP'), button:has-text('Set up'), [data-action='enable-mfa']",
          "announce": { "before": "Clicking Enable MFA" }
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "screenshot",
          "value": "awnic-mfa-02-qr-code.png",
          "announce": { "after": "TOTP QR code displayed for scanning" }
        },
        {
          "action": "custom",
          "handler": "generateTotp",
          "description": "Generate TOTP code from displayed secret to verify setup",
          "params": {
            "command": "ssh sovpn 'bash /tmp/get-totp.sh'"
          },
          "selector": "input[inputmode='numeric'], input[maxlength='6'], input[placeholder*='code' i], input[placeholder='000000']",
          "announce": { "before": "Generating TOTP verification code", "after": "TOTP code entered for verification" }
        },
        {
          "action": "click",
          "selector": "button[type='submit'], button:has-text('Verify'), button:has-text('Confirm'), button:has-text('Activate')",
          "announce": { "after": "MFA verification submitted" }
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "screenshot",
          "value": "awnic-mfa-03-enabled.png",
          "announce": { "after": "MFA successfully enabled on the account" }
        }
      ]
    },

    "mfa-relogin": {
      "name": "Logout and Re-login with MFA",
      "description": "Logout, then re-login to verify MFA challenge appears and can be completed",
      "steps": [
        {
          "action": "click",
          "selector": "button[class*='avatar'], [data-testid='user-menu'], button[aria-label*='profile']",
          "announce": { "before": "Logging out to test MFA re-login" }
        },
        {
          "action": "wait",
          "timeout": 800
        },
        {
          "action": "click",
          "selector": "button:has-text('Logout'), button:has-text('Sign out'), a:has-text('Logout'), [role='menuitem']:has-text('Log')"
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "waitForUrl",
          "pattern": "/(login|signin|auth)",
          "timeout": 15000,
          "announce": { "after": "Logged out. Now re-logging in with MFA." }
        },
        {
          "action": "fill",
          "selector": "input[type='email'], input[placeholder*='email' i], input[name='email']",
          "value": "${credentials.admin.email}"
        },
        {
          "action": "fill",
          "selector": "input[type='password']",
          "value": "${credentials.admin.password}"
        },
        {
          "action": "click",
          "selector": "button[type='submit'], button:has-text('Sign in'), button:has-text('Login')",
          "announce": { "after": "Credentials submitted, expecting MFA challenge" }
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "assertVisible",
          "selector": "input[inputmode='numeric'], input[maxlength='6'], input[placeholder='000000']",
          "timeout": 10000,
          "announce": { "after": "MFA challenge is displayed" }
        },
        {
          "action": "screenshot",
          "value": "awnic-mfa-relogin-01-challenge.png"
        },
        {
          "action": "custom",
          "handler": "generateTotp",
          "description": "Generate TOTP for MFA re-login",
          "params": {
            "command": "ssh sovpn 'bash /tmp/get-totp.sh'"
          },
          "selector": "input[inputmode='numeric'], input[maxlength='6'], input[placeholder='000000']",
          "announce": { "before": "Generating TOTP code", "after": "TOTP entered" }
        },
        {
          "action": "click",
          "selector": "button[type='submit'], button:has-text('Verify'), button:has-text('Confirm')",
          "announce": { "after": "MFA verification submitted" }
        },
        {
          "action": "wait",
          "timeout": 3000
        },
        {
          "action": "waitForUrl",
          "pattern": "/(dashboard|home|app)",
          "timeout": 20000,
          "announce": { "after": "MFA re-login successful. Dashboard loaded." }
        },
        {
          "action": "screenshot",
          "value": "awnic-mfa-relogin-02-success.png"
        }
      ]
    },

    "create-org": {
      "name": "Create AWNIC Organization",
      "description": "Create a new organization of type Insurance/Cedent named AWNIC (Al Wathba National Insurance Company)",
      "steps": [
        {
          "action": "click",
          "selector": "button[class*='hamburger'], button[aria-label*='menu'], [data-testid='menu-toggle']",
          "force": true,
          "announce": { "before": "Opening menu to navigate to Organizations" }
        },
        {
          "action": "wait",
          "timeout": 800
        },
        {
          "action": "click",
          "selector": "a:has-text('Organizations'), nav a[href*='organization']",
          "force": true,
          "announce": { "before": "Clicking Organizations menu item" }
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "screenshot",
          "value": "awnic-org-01-list.png"
        },
        {
          "action": "click",
          "selector": "button:has-text('New Organization'), button:has-text('Add Organization'), button:has-text('Create'), a:has-text('New Org')",
          "announce": { "before": "Clicking New Organization button" }
        },
        {
          "action": "wait",
          "timeout": 1500
        },
        {
          "action": "screenshot",
          "value": "awnic-org-02-form.png"
        },
        {
          "action": "fill",
          "selector": "input[name='name'], input[placeholder*='name' i], input[placeholder*='organization' i]",
          "value": "AWNIC",
          "announce": { "before": "Entering organization name: AWNIC" }
        },
        {
          "action": "fill",
          "selector": "input[name='fullName'], input[name='displayName'], input[placeholder*='full name' i], input[placeholder*='display' i]",
          "value": "Al Wathba National Insurance Company"
        },
        {
          "action": "click",
          "selector": "select[name*='type'], [data-testid*='type-select'], button:has-text('Select Type'), [class*='type-selector']",
          "announce": { "before": "Selecting organization type" }
        },
        {
          "action": "wait",
          "timeout": 800
        },
        {
          "action": "click",
          "selector": "[data-value*='insurance'], option:has-text('Insurance'), li:has-text('Insurance'), div:has-text('Insurance'), [data-value*='cedent'], option:has-text('Cedent'), li:has-text('Cedent')",
          "announce": { "after": "Selected Insurance/Cedent type" }
        },
        {
          "action": "wait",
          "timeout": 500
        },
        {
          "action": "screenshot",
          "value": "awnic-org-03-filled.png"
        },
        {
          "action": "click",
          "selector": "button[type='submit'], button:has-text('Create'), button:has-text('Save'), button:has-text('Submit')",
          "announce": { "before": "Submitting AWNIC organization creation" }
        },
        {
          "action": "wait",
          "timeout": 3000
        },
        {
          "action": "screenshot",
          "value": "awnic-org-04-created.png",
          "announce": { "after": "AWNIC organization created successfully" }
        }
      ]
    },


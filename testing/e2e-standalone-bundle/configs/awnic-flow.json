  "journeys": {
    "setup": {
      "name": "Platform Setup",
      "description": "Login with admin credentials, enable MFA, re-login to verify MFA, then logout",
      "segments": ["login", "enable-mfa", "mfa-relogin"]
    },
    "org-setup": {
      "name": "AWNIC Organization Setup",
      "description": "Create AWNIC organization and 5 role-based users",
      "segments": ["create-org", "create-users"]
    },
    "product-config": {
      "name": "Product Configuration",
      "description": "Configure health insurance products and pricing via Farooq and Hessa",
      "segments": ["configure-product", "configure-rater"]
    },
    "quotation-flow": {
      "name": "Quotation to Policy Flow",
      "description": "End-to-end flow: create quotation, manual underwrite, payment, policy issuance",
      "segments": ["create-quotation", "manual-underwrite", "payment-flow", "policy-issuance"]
    },
    "notifications": {
      "name": "Stakeholder Notifications",
      "description": "Verify broker and distributor notifications at each stage",
      "segments": ["stakeholder-notifications"]
    },
    "automation": {
      "name": "Rules and Automation",
      "description": "Create STP rules, test automated processing, test queue scenarios",
      "segments": ["create-rules", "test-auto-rules", "test-queues"]
    },
    "data-quality": {
      "name": "Data Quality and Guides",
      "description": "AI synthetic data generation and Guide section verification",
      "segments": ["ai-synthetic-data", "verify-guides"]
    },
    "security-pii": {
      "name": "Security and PII Verification",
      "description": "Verify PII tokenization and nickname replacement in underwriter views",
      "segments": ["verify-pii-tokenization", "verify-nicknames"]
    }
  },

  "bouquets": {
    "awnic-full": {
      "name": "AWNIC Full E2E",

  "segments": {

    "login-flow": {
      "name": "Login",
      "description": "Authenticate as admin",
      "steps": [
        {
          "action": "navigate",
          "url": "/login",
          "announce": { "before": "Master Test Plan: logging in" }
        },
        { "action": "wait", "timeout": 1500 },
        {
          "action": "assertVisible",
          "selector": "input[type='email'], input[name='email'], input[placeholder*='email' i]",
          "timeout": 10000
        },
        {
          "action": "fill",
          "selector": "input[type='email'], input[name='email'], input[placeholder*='email' i]",
          "value": "${credentials.admin.email}"
        },
        {
          "action": "fill",
          "selector": "input[type='password']",
          "value": "${credentials.admin.password}"
        },
        {
          "action": "click",
          "selector": "button[type='submit'], button:has-text('Sign in'), button:has-text('Login')"
        },
        { "action": "wait", "timeout": 4000 },
        {
          "action": "assertVisible",
          "selector": "nav, aside, [class*='sidebar'], [role='navigation'], main",
          "timeout": 20000,
          "announce": { "after": "Authenticated for master test plan" }
        },
        {
          "action": "screenshot",
          "value": "master-00-login.png"
        }
      ]
    },

    "thread-a-health-checks": {

        {
          "action": "apiCheck",
          "endpoint": "/api/zmb-factory/api/v1/G/zmb-factory/health",
          "expectedStatus": [200],
          "announce": { "before": "ZMB Factory", "after": "ZMB Factory: healthy" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/pcg4/api/v1/G/health",
          "expectedStatus": [200, 404],
          "announce": { "before": "PCG4", "after": "PCG4: responded" }

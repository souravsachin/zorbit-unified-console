      "description": "UW Workflow, White Label, AI Gateway, Product Pricing, PCG4",
      "segments": ["thread-e-modules"]
    },

    "master-all": {
      "name": "Master: All Threads",
      "description": "Complete platform verification: all 5 threads in sequence",
      "segments": [
        "thread-a-health-checks",
        "login-flow",
        "thread-b-rbac",
        "thread-c-ui-consistency",
        "thread-d-walkthrough",
        "thread-e-modules"

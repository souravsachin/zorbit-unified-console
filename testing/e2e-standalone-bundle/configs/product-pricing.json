  "journeys": {
    "pricing-happy-path": {
      "name": "Product Pricing Happy Path",
      "description": "Quick happy-path: login, navigate to pricing, view rate tables, select one, check lookup",
      "segments": [
        "pricing-login",
        "pricing-navigate",
        "pricing-list-products",
        "pricing-select-product",
        "pricing-premium-lookup"
      ]
    },
    "pricing-full-regression": {
      "name": "Product Pricing Full Regression",
      "description": "Complete regression covering all pricing pages and placeholder features",
      "segments": [
        "pricing-login",
        "pricing-navigate",
        "pricing-list-products",
        "pricing-select-product",
        "pricing-configure-rates",
        "pricing-age-bands",
        "pricing-gender-rates",
        "pricing-member-types",
        "pricing-copay-setup",
        "pricing-save-publish",
        "pricing-import-rate-card",
        "pricing-premium-lookup",
        "pricing-setup-page",
        "pricing-deployments-page"
      ]
    },
    "pricing-pages-only": {
      "name": "Product Pricing Page Renders",
      "description": "Verify all product pricing pages render without errors (no data interaction)",
      "segments": [
        "pricing-login",
        "pricing-navigate",
        "pricing-list-products",
        "pricing-import-rate-card",
        "pricing-setup-page",
        "pricing-deployments-page"
      ]
    }
  },

  "bouquets": {
    "pricing-quick": {
      "name": "Product Pricing Quick Test",

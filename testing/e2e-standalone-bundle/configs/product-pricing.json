{
  "baseUrl": "https://zorbit.scalatics.com",
  "viewport": { "width": 1280, "height": 720 },
  "defaults": {
    "timeout": 10000,
    "waitAfterAction": 500,
    "waitForNetworkIdle": false
  },
  "segments": {
    "pricing-login": {
      "name": "Login for Product Pricing",
      "description": "Login with admin credentials that have product-pricing access",
      "steps": [
        {
          "action": "navigate",
          "url": "/login",
          "announce": { "before": "Loading login page for Product Pricing tests" }
        },
        {
          "action": "wait",
          "timeout": 1500
        },
        {
          "action": "fill",
          "selector": "input[type='email'], input[placeholder*='email' i], input[name='email']",
          "value": "${credentials.admin.email}"
        },
        {
          "action": "fill",
          "selector": "input[type='password']",
          "value": "${credentials.admin.password}"
        },
        {
          "action": "click",
          "selector": "button[type='submit'], button:has-text('Sign in'), button:has-text('Login')",
          "announce": { "after": "Login submitted" }
        },
        {
          "action": "wait",
          "timeout": 3000
        },
        {
          "action": "custom",
          "handler": "generateTotp",
          "description": "Generate TOTP for MFA if challenged",
          "params": {
            "command": "ssh sovpn 'bash /tmp/get-totp.sh'"
          },
          "selector": "input[inputmode='numeric'], input[maxlength='6'], input[placeholder='000000']"
        },
        {
          "action": "click",
          "selector": "button[type='submit'], button:has-text('Verify')"
        },
        {
          "action": "wait",
          "timeout": 3000
        },
        {
          "action": "waitForUrl",
          "pattern": "^https://zorbit\\.scalatics\\.com/?$",
          "timeout": 20000,
          "announce": { "after": "Successfully logged in" }
        },
        {
          "action": "screenshot",
          "value": "pricing-login-01-dashboard.png"
        }
      ]
    },

    "pricing-navigate": {
      "name": "Navigate to Product Pricing",
      "description": "Open sidebar and navigate to the Product Pricing section",
      "steps": [
        {
          "action": "click",
          "selector": "button[class*='hamburger'], button[aria-label*='menu'], [data-testid='menu-toggle'], button[class*='sidebar-toggle']",
          "force": true,
          "announce": { "before": "Opening sidebar menu" }
        },
        {
          "action": "wait",
          "timeout": 1000
        },
        {
          "action": "assertVisible",
          "selector": "nav, [role='navigation'], [class*='sidebar'], [class*='menu']",
          "timeout": 8000,
          "announce": { "after": "Sidebar menu is visible" }
        },
        {
          "action": "screenshot",
          "value": "pricing-navigate-01-sidebar.png"
        },
        {
          "action": "click",
          "selector": "a[href*='product-pricing'], button:has-text('Product Pricing'), [class*='menu'] :text('Product Pricing')",
          "announce": { "after": "Clicked Product Pricing menu item" }
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "waitForUrl",
          "pattern": "/product-pricing",
          "timeout": 10000,
          "announce": { "after": "Product Pricing hub loaded" }
        },
        {
          "action": "screenshot",
          "value": "pricing-navigate-02-hub.png"
        }
      ]
    },

    "pricing-list-products": {
      "name": "View Rate Tables List",
      "description": "Navigate to the rate tables page and verify the list renders",
      "steps": [
        {
          "action": "navigate",
          "url": "/product-pricing/rate-tables",
          "announce": { "before": "Loading rate tables list" }
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "assertVisible",
          "selector": "h1, [class*='heading'], [class*='title']",
          "timeout": 10000,
          "announce": { "after": "Rate Tables heading is visible" }
        },
        {
          "action": "screenshot",
          "value": "pricing-list-01-rate-tables.png"
        },
        {
          "action": "assertVisible",
          "selector": "table, [class*='table'], [class*='list'], [class*='card'], [class*='grid']",
          "timeout": 10000,
          "announce": { "after": "Rate tables list or empty state rendered" }
        },
        {
          "action": "screenshot",
          "value": "pricing-list-02-table-content.png"
        }
      ]
    },

    "pricing-select-product": {
      "name": "Select a Rate Table",
      "description": "Click on a rate table row to view its details",
      "steps": [
        {
          "action": "navigate",
          "url": "/product-pricing/rate-tables",
          "announce": { "before": "Loading rate tables list" }
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "click",
          "selector": "table tbody tr:first-child, [class*='card']:first-child, [class*='table-row']:first-child, [class*='list-item']:first-child",
          "announce": { "after": "Selected first rate table" }
        },
        {
          "action": "wait",
          "timeout": 1500
        },
        {
          "action": "assertVisible",
          "selector": "[class*='detail'], [class*='panel'], [class*='drawer'], [class*='modal'], table",
          "timeout": 10000,
          "announce": { "after": "Rate table detail view is visible" }
        },
        {
          "action": "screenshot",
          "value": "pricing-select-01-detail.png"
        }
      ]
    },

    "pricing-configure-rates": {
      "name": "Configure Pricing Rates",

      "mode": "sequential",
      "journeys": ["pricing-happy-path"]
    },
    "pricing-full": {
      "name": "Product Pricing Full Suite",
      "description": "Complete regression covering all product pricing features and placeholder segments",
      "mode": "sequential",
      "journeys": ["pricing-full-regression"]

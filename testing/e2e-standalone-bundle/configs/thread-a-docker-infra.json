    "infra-seed": {
      "name": "Module Seeding (IN-2033)",
      "description": "Verify all seed endpoints are accessible via HTTPS",
      "segments": ["login-via-https", "seed-all-modules"]
    },

    "infra-nginx": {
      "name": "Nginx Proxy Routes (IN-2035)",
      "description": "Verify all API routes work through nginx reverse proxy",
      "segments": ["nginx-proxy-routes"]
    },

    "infra-full": {
      "name": "Full Infrastructure Verification",
      "description": "Complete infrastructure check: HTTPS, health, login, navigation, seed, nginx",
      "segments": [
        "https-connectivity",
        "health-all-16-services",
        "login-via-https",
        "navigation-menu-from-db",
        "seed-all-modules",
        "nginx-proxy-routes"
      ]
    }
  },

  "bouquets": {

    "health-checks": {
      "name": "Health Checks Only",

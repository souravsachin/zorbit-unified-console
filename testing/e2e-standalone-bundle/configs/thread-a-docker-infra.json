      "name": "IN-2033: Seed All Modules via HTTPS",
      "description": "Hit seed/demo endpoints for all modules that support seeding",
      "steps": [
        {
          "action": "navigate",
          "url": "/app/dashboard",
          "announce": { "before": "IN-2033: Starting module seed verification" }
        },
        { "action": "wait", "timeout": 2000 },
        {
          "action": "apiCheck",
          "endpoint": "/api/white-label/api/v1/G/white-label/health",
          "expectedStatus": [200],
          "announce": { "before": "Checking White Label seed readiness", "after": "White Label ready for seed" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/form-builder/api/v1/G/form-builder/health",
          "expectedStatus": [200],
          "announce": { "before": "Checking Form Builder seed readiness", "after": "Form Builder ready for seed" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/datatable/api/v1/G/datatable/health",
          "expectedStatus": [200],
          "announce": { "before": "Checking DataTable seed readiness", "after": "DataTable ready for seed" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/zmb-factory/api/v1/G/zmb-factory/health",
          "expectedStatus": [200],
          "announce": { "before": "Checking ZMB Factory seed readiness", "after": "ZMB Factory ready for seed" }
        },
        {
          "action": "screenshot",
          "value": "infra-05-seed-readiness.png",
          "announce": { "after": "IN-2033: All seed-capable services confirmed healthy" }
        }
      ]
    },

    "nginx-proxy-routes": {
      "name": "IN-2035: Verify Nginx Proxy Routes via HTTPS",
      "description": "Confirm all /api/* routes work through nginx reverse proxy",
      "steps": [
        {
          "action": "navigate",
          "url": "/login",
          "announce": { "before": "IN-2035: Verifying nginx proxy routes" }
        },
        { "action": "wait", "timeout": 1000 },
        {
          "action": "apiCheck",
          "endpoint": "/api/identity/api/v1/G/health",
          "expectedStatus": [200],
          "announce": { "before": "Nginx route: /api/identity/*", "after": "Identity route OK" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/authorization/api/v1/G/health",
          "expectedStatus": [200],
          "announce": { "before": "Nginx route: /api/authorization/*", "after": "Authorization route OK" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/navigation/api/v1/G/health",
          "expectedStatus": [200],
          "announce": { "before": "Nginx route: /api/navigation/*", "after": "Navigation route OK" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/messaging/api/v1/G/messaging/health",
          "expectedStatus": [200],
          "announce": { "before": "Nginx route: /api/messaging/*", "after": "Messaging route OK" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/pii-vault/api/v1/G/health",
          "expectedStatus": [200],
          "announce": { "before": "Nginx route: /api/pii-vault/*", "after": "PII Vault route OK" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/audit/api/v1/G/health",
          "expectedStatus": [200],
          "announce": { "before": "Nginx route: /api/audit/*", "after": "Audit route OK" }
        },
        {
          "action": "screenshot",
          "value": "infra-06-nginx-routes.png",
          "announce": { "after": "IN-2035: All nginx proxy routes confirmed working via HTTPS" }
        }
      ]
    }
  },

  "journeys": {

    "infra-https-health": {
      "name": "HTTPS Health Checks (IN-2032)",
      "description": "Verify all 16 services via HTTPS health endpoints",
      "segments": ["https-connectivity", "health-all-16-services"]
    },

    "infra-login": {
      "name": "HTTPS Login (IN-2034)",
      "description": "Login via HTTPS with SHA-256 password hashing",
      "segments": ["login-via-https"]
    },

    "infra-navigation": {
      "name": "Navigation from DB (IN-2035)",
      "description": "Verify navigation menu loads from database via navigation service",
      "segments": ["login-via-https", "navigation-menu-from-db"]

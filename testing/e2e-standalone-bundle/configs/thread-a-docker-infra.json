{
  "_meta": {
    "description": "Thread A — Docker Infrastructure: health checks, login, navigation for tickets IN-2023 through IN-2038",
    "updated": "2026-04-15",
    "tickets": ["IN-2023", "IN-2024", "IN-2025", "IN-2026", "IN-2027", "IN-2028", "IN-2029", "IN-2030", "IN-2031", "IN-2032", "IN-2033", "IN-2034", "IN-2035", "IN-2036", "IN-2037", "IN-2038"]
  },
  "baseUrl": "https://zorbit-uat.onezippy.ai",
  "viewport": { "width": 1440, "height": 900 },
  "defaults": {
    "timeout": 20000,
    "waitAfterAction": 700,
    "waitForNetworkIdle": false
  },

  "segments": {

    "https-connectivity": {
      "name": "IN-2032: HTTPS Connectivity Check",
      "description": "Verify the UAT site is reachable over HTTPS",
      "steps": [
        {
          "action": "navigate",
          "url": "/login",
          "announce": { "before": "IN-2032: Verifying HTTPS connectivity to zorbit-uat.onezippy.ai" }
        },
        { "action": "wait", "timeout": 2000 },
        {
          "action": "assertVisible",
          "selector": "body",
          "timeout": 15000,
          "announce": { "after": "HTTPS site is reachable" }
        },
        {
          "action": "screenshot",
          "value": "infra-00-https-reachable.png"
        }
      ]
    },

    "health-all-16-services": {
      "name": "IN-2032: Health Check All 16 Services via HTTPS",
      "description": "Health check every deployed service through nginx proxy over HTTPS",
      "steps": [
        {
          "action": "navigate",
          "url": "/login",
          "announce": { "before": "IN-2032: Starting health checks for all 16 services via HTTPS" }
        },
        { "action": "wait", "timeout": 1000 },
        {
          "action": "apiCheck",
          "endpoint": "/api/identity/api/v1/G/health",
          "expectedStatus": [200],
          "announce": { "before": "IN-2027: Identity health (zu-core)", "after": "Identity: healthy" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/authorization/api/v1/G/health",
          "expectedStatus": [200],
          "announce": { "before": "IN-2027: Authorization health (zu-core)", "after": "Authorization: healthy" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/navigation/api/v1/G/health",
          "expectedStatus": [200],
          "announce": { "before": "IN-2027: Navigation health (zu-core)", "after": "Navigation: healthy" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/messaging/api/v1/G/messaging/health",
          "expectedStatus": [200],
          "announce": { "before": "IN-2027: Event Bus health (zu-core)", "after": "Event Bus: healthy" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/pii-vault/api/v1/G/health",

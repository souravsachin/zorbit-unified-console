          "announce": { "before": "IN-2027: PII Vault health (zu-core)", "after": "PII Vault: healthy" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/audit/api/v1/G/health",
          "expectedStatus": [200],
          "announce": { "before": "IN-2027: Audit health (zu-core)", "after": "Audit: healthy" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/form-builder/api/v1/G/form-builder/health",
          "expectedStatus": [200],
          "announce": { "before": "IN-2028: Form Builder health (zu-pfs)", "after": "Form Builder: healthy" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/datatable/api/v1/G/datatable/health",
          "expectedStatus": [200],
          "announce": { "before": "IN-2028: DataTable health (zu-pfs)", "after": "DataTable: healthy" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/product-pricing/api/v1/G/health",
          "expectedStatus": [200],
          "announce": { "before": "IN-2028: Product Pricing health (zu-pfs)", "after": "Product Pricing: healthy" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/doc-generator/api/v1/G/health",
          "expectedStatus": [200],
          "announce": { "before": "IN-2028: Doc Generator health (zu-pfs)", "after": "Doc Generator: healthy" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/white-label/api/v1/G/white-label/health",
          "expectedStatus": [200],
          "announce": { "before": "IN-2028: White Label health (zu-pfs)", "after": "White Label: healthy" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/zmb-factory/api/v1/G/zmb-factory/health",
          "expectedStatus": [200],
          "announce": { "before": "IN-2028: ZMB Factory health (zu-pfs)", "after": "ZMB Factory: healthy" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/pcg4/api/v1/G/health",
          "expectedStatus": [200, 404],
          "announce": { "before": "IN-2029: PCG4 health (zu-apps)", "after": "PCG4: responded" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/hi-quotation/api/v1/G/health",
          "expectedStatus": [200],
          "announce": { "before": "IN-2029: HI Quotation health (zu-apps)", "after": "HI Quotation: healthy" }

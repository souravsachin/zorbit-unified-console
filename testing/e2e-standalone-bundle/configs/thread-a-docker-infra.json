    "login-via-https": {
      "name": "IN-2034: Login via HTTPS with SHA-256 Password",
      "description": "Authenticate as admin via HTTPS, verify JWT returned and dashboard loads",
      "steps": [
        {
          "action": "navigate",
          "url": "/login",
          "announce": { "before": "IN-2034: Navigating to login page via HTTPS" }
        },
        { "action": "wait", "timeout": 1500 },
        {
          "action": "assertVisible",
          "selector": "input[type='email'], input[name='email'], input[placeholder*='email' i]",
          "timeout": 10000,
          "announce": { "after": "Login form visible" }
        },
        {
          "action": "fill",
          "selector": "input[type='email'], input[name='email'], input[placeholder*='email' i]",
          "value": "${credentials.admin.email}"
        },
        {
          "action": "fill",
          "selector": "input[type='password']",
          "value": "${credentials.admin.password}"
        },
        {
          "action": "click",
          "selector": "button[type='submit'], button:has-text('Sign in'), button:has-text('Login')",
          "announce": { "after": "IN-2034: Login submitted via HTTPS with SHA-256 hashed password" }
        },
        { "action": "wait", "timeout": 4000 },
        {
          "action": "assertVisible",
          "selector": "nav, aside, [class*='sidebar'], [role='navigation'], main",
          "timeout": 20000,
          "announce": { "after": "Dashboard loaded. HTTPS authentication successful." }
        },
        {
          "action": "screenshot",
          "value": "infra-02-login-success.png"
        }
      ]
    },

    "navigation-menu-from-db": {
      "name": "IN-2035: Verify Navigation Menu Loads from DB",
      "description": "After login, verify sidebar/navigation menu loads dynamically from the navigation service",
      "steps": [
        {
          "action": "navigate",
          "url": "/app/dashboard",
          "announce": { "before": "IN-2035: Verifying navigation menu loads from DB" }
        },
        { "action": "wait", "timeout": 3000 },
        {
          "action": "assertVisible",
          "selector": "nav, aside, [class*='sidebar'], [role='navigation']",
          "timeout": 15000,
          "announce": { "after": "Sidebar navigation rendered" }
        },
        {
          "action": "assertVisible",
          "selector": "a[href*='/app/'], [class*='menu-item'], [class*='nav-item'], li a",
          "timeout": 10000,
          "announce": { "after": "Navigation menu items loaded from DB" }
        },
        {
          "action": "screenshot",
          "value": "infra-03-nav-menu-loaded.png"
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/navigation/api/v1/G/health",
          "expectedStatus": [200],
          "announce": { "before": "Confirming navigation service is serving menu data", "after": "Navigation service confirmed healthy" }
        },
        {
          "action": "screenshot",
          "value": "infra-04-nav-api-confirmed.png",
          "announce": { "after": "Navigation menu from DB verified" }
        }
      ]
    },

